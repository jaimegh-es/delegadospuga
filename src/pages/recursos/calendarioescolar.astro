---
import ResourceLayout from '../../layouts/ResourceLayout.astro';
---

<ResourceLayout title="Calendario Escolar" description="Descubre los días que no hay instituto este año.">
	<img class="calendario-img" src={import.meta.env.BASE_URL + "calendarioescolar.png"} alt="Calendario escolar" />
</ResourceLayout>

<style>
.calendario-img {
  max-width: 100%;
  height: auto;
  display: block;
  margin: 1.5rem auto;
  border-radius: 12px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
}
</style>

