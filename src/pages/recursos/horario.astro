---
import ResourceLayout from '../../layouts/ResourceLayout.astro';
---

<ResourceLayout title="Horario de clases" description="¡Que no se te escape ni una hora!">
	<img class="horario-img" src={import.meta.env.BASE_URL + "horario-secure.png"} alt="Horario de clases" />
</ResourceLayout>

<style>
.horario-img {
  max-width: 100%;
  height: auto;
  display: block;
  margin: 1.5rem auto;
  border-radius: 12px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
}
</style>

