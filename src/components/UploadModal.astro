---
---

<div id="uploadModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <div class="header-left">
        <div class="header-icon">
          <i class="fa-solid fa-cloud-arrow-up"></i>
        </div>
        <h2>Subir Archivo</h2>
      </div>
      <button class="close-btn" id="closeUploadModal">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    
    <div class="modal-body">
      <form id="uploadForm">
        <input type="hidden" name="path" value="public/uploads" />
        
        <!-- Drop Zone -->
        <div class="drop-zone" id="dropZone">
          <div class="drop-zone-content">
            <div class="icon-circle">
              <i class="fa-solid fa-file-circle-plus"></i>
            </div>
            <p class="main-text">Arrastra un archivo o haz clic para seleccionar</p>
            <p class="sub-text">Imágenes, PDFs o documentos (máx. 25MB)</p>
          </div>
          <input type="file" name="file" id="fileInput" hidden />
          <div id="fileNameDisplay" class="file-badge hidden"></div>
        </div>

        <!-- GitHub Token Section -->
        <div class="token-section">
          <div class="token-header">
            <label>
              <i class="fa-brands fa-github"></i> GitHub Access Token
            </label>
            <a href="https://github.com/settings/tokens/new?scopes=repo&description=1bach%20Panel%20Upload" target="_blank">
              Obtener token <i class="fa-solid fa-external-link"></i>
            </a>
          </div>
          <input type="password" name="token" id="githubToken" placeholder="ghp_xxxxxxxxxxxx" required />
          <p class="token-footer">Se guardará en tu navegador para futuras subidas.</p>
        </div>

        <!-- Status & Progress -->
        <div id="uploadStatus" class="status-container hidden">
          <div class="status-info">
             <span id="statusMessage">Subiendo...</span>
             <span id="progressPercent">0%</span>
          </div>
          <div class="progress-bar">
            <div id="progressFill" class="progress-fill"></div>
          </div>
        </div>

        <!-- Action Button -->
        <button type="submit" class="submit-button" id="submitUploadBtn">
          <i class="fa-solid fa-arrow-up-from-bracket"></i> Iniciar Subida
        </button>
      </form>
    </div>
  </div>
</div>

<style>
  /* Modal Base */
  .modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(15, 23, 42, 0.7);
    backdrop-filter: blur(8px);
    z-index: 10000; /* Aseguramos que esté por encima de todo */
    align-items: center;
    justify-content: center;
    padding: 20px;
    font-family: system-ui, -apple-system, sans-serif;
  }

  .modal.show {
    display: flex;
  }

  /* Modal Content */
  .modal-content {
    background: #ffffff;
    width: 100%;
    max-width: 500px;
    border-radius: 24px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    overflow: hidden;
    animation: modal-slide-up 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes modal-slide-up {
    from { opacity: 0; transform: translateY(30px) scale(0.95); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* Header */
  .modal-header {
    padding: 24px 24px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .header-icon {
    background: #eff6ff;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #2000ad;
    font-size: 1.2rem;
  }

  .modal-header h2 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 700;
    color: #0f172a;
  }

  .close-btn {
    background: #f8fafc;
    border: none;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    cursor: pointer;
    color: #64748b;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }

  .close-btn:hover {
    background: #f1f5f9;
    color: #0f172a;
    transform: rotate(90deg);
  }

  /* Body & Form */
  .modal-body {
    padding: 0 24px 32px;
  }

  #uploadForm {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* Drop Zone */
  .drop-zone {
    border: 2px dashed #e2e8f0;
    border-radius: 20px;
    padding: 40px 20px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    background: #ffffff;
  }

  .drop-zone:hover, .drop-zone.dragover {
    border-color: #2000ad;
    background: #f0f4ff;
  }

  .drop-zone-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .icon-circle {
    background: #f8fafc;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #94a3b8;
    font-size: 1.5rem;
    transition: all 0.2s;
  }

  .drop-zone:hover .icon-circle {
    background: #eff6ff;
    color: #2000ad;
  }

  .main-text {
    margin: 0;
    font-weight: 600;
    color: #334155;
    font-size: 0.95rem;
  }

  .sub-text {
    margin: 0;
    font-size: 0.75rem;
    color: #94a3b8;
  }

  .file-badge {
    margin-top: 16px;
    background: #eff6ff;
    color: #2000ad;
    padding: 6px 16px;
    border-radius: 99px;
    font-size: 0.85rem;
    font-weight: 600;
    display: inline-block;
  }

  .hidden { display: none; }

  /* Token Section */
  .token-section {
    background: #f8fafc;
    padding: 16px;
    border-radius: 16px;
    border: 1px solid #f1f5f9;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .token-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .token-header label {
    font-size: 0.85rem;
    font-weight: 700;
    color: #475569;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .token-header a {
    font-size: 0.75rem;
    color: #2000ad;
    text-decoration: none;
    font-weight: 600;
  }

  .token-header a:hover { text-decoration: underline; }

  #githubToken {
    width: 100%;
    padding: 12px;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    font-size: 0.9rem;
    outline: none;
    transition: all 0.2s;
    box-sizing: border-box;
  }

  #githubToken:focus {
    border-color: #2000ad;
    box-shadow: 0 0 0 3px rgba(32, 0, 173, 0.1);
  }

  .token-footer {
    margin: 0;
    font-size: 0.7rem;
    color: #94a3b8;
  }

  /* Progress bar */
  .status-container {
    animation: fade-in 0.3s ease-out;
  }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .status-info {
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
    font-size: 0.75rem;
    font-weight: 700;
    color: #475569;
  }

  #progressPercent { color: #2000ad; }

  .progress-bar {
    width: 100%;
    height: 8px;
    background: #f1f5f9;
    border-radius: 99px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: #2000ad;
    width: 0%;
    transition: width 0.3s ease;
    border-radius: 99px;
  }

  /* Submit Button */
  .submit-button {
    width: 100%;
    background: #2000ad;
    color: white;
    padding: 16px;
    border: none;
    border-radius: 16px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: all 0.2s;
    box-shadow: 0 4px 12px rgba(32, 0, 173, 0.2);
  }

  .submit-button:hover {
    background: #1a008d;
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(32, 0, 173, 0.25);
  }

  .submit-button:active {
    transform: translateY(0);
  }

  .submit-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }
</style>

<script>
  const modal = document.getElementById('uploadModal');
  const closeBtn = document.getElementById('closeUploadModal');
  const uploadForm = document.getElementById('uploadForm') as HTMLFormElement;
  const fileInput = document.getElementById('fileInput') as HTMLInputElement;
  const fileNameDisplay = document.getElementById('fileNameDisplay');
  const dropZone = document.getElementById('dropZone');
  const statusDiv = document.getElementById('uploadStatus');
  const progressFill = document.getElementById('progressFill') as HTMLElement;
  const progressPercent = document.getElementById('progressPercent');
  const statusMessage = document.getElementById('statusMessage');
  const submitBtn = document.getElementById('submitUploadBtn') as HTMLButtonElement;
  const tokenInput = document.getElementById('githubToken') as HTMLInputElement;

  // Cargar token guardado
  const savedToken = localStorage.getItem('github_upload_token');
  if (savedToken) tokenInput.value = savedToken;

  // Abrir modal (desde evento global)
  window.addEventListener('open-upload-modal', (e: any) => {
    modal?.classList.add('show');
    if (e.detail?.mode) {
        modal?.setAttribute('data-mode', e.detail.mode);
    }
  });

  const closeModal = () => {
    modal?.classList.remove('show');
    setTimeout(resetForm, 300);
  };

  closeBtn?.addEventListener('click', closeModal);

  // Cerrar al hacer clic fuera
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // Drag & Drop
  dropZone?.addEventListener('click', () => fileInput?.click());
  dropZone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('dragover');
  });
  dropZone?.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
  dropZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('dragover');
    if (e.dataTransfer?.files.length) {
      fileInput.files = e.dataTransfer.files;
      updateFileName();
    }
  });

  fileInput?.addEventListener('change', updateFileName);

  function updateFileName() {
    if (fileInput.files?.length) {
      fileNameDisplay!.textContent = fileInput.files[0].name;
      fileNameDisplay!.classList.remove('hidden');
    } else {
      fileNameDisplay!.classList.add('hidden');
    }
  }

  function resetForm() {
    uploadForm.reset();
    if (savedToken) tokenInput.value = savedToken;
    fileNameDisplay!.textContent = '';
    fileNameDisplay!.classList.add('hidden');
    statusDiv?.classList.add('hidden');
    submitBtn.disabled = false;
    progressFill!.style.width = '0%';
    progressPercent!.textContent = '0%';
    statusMessage!.textContent = 'Subiendo...';
    statusMessage!.style.color = 'inherit';
    progressFill!.style.backgroundColor = '#2000ad';
  }

  uploadForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const file = fileInput.files?.[0];
    const token = tokenInput.value.trim();
    const repo = 'jaimegh-es/delegadospuga';
    
    if (!file || !token) return;

    localStorage.setItem('github_upload_token', token);

    submitBtn.disabled = true;
    statusDiv?.classList.remove('hidden');
    
    progressFill!.style.width = '20%';
    progressPercent!.textContent = '20%';
    statusMessage!.textContent = 'Codificando archivo...';

    try {
      const base64 = await new Promise<string>((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => {
          const result = reader.result as string;
          resolve(result.split(',')[1]);
        };
        reader.onerror = reject;
        reader.readAsDataURL(file);
      });

      progressFill!.style.width = '50%';
      progressPercent!.textContent = '50%';
      statusMessage!.textContent = 'Subiendo a GitHub...';

      const fileName = file.name.replace(/\s+/g, '-');
      const finalPath = `public/uploads/${fileName}`;

      const response = await fetch(`https://api.github.com/repos/${repo}/contents/${finalPath}`, {
        method: 'PUT',
        headers: {
          'Authorization': `token ${token}`,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          message: `Upload ${fileName} via 1bach Admin Panel`,
          content: base64,
          branch: 'main'
        })
      });

      const result = await response.json();

      if (!response.ok) {
        if (result.message?.includes('already exists')) {
             throw new Error('Ya existe un archivo con ese nombre');
        }
        throw new Error(result.message || 'Error al subir');
      }

      progressFill!.style.width = '100%';
      progressPercent!.textContent = '100%';
      statusMessage!.textContent = '¡Completado con éxito!';
      statusMessage!.style.color = '#059669';
      
      const fileUrl = `/uploads/${fileName}`;
      const mode = modal?.getAttribute('data-mode');

      window.dispatchEvent(new CustomEvent('file-uploaded', {
        detail: {
            url: fileUrl,
            mode: mode,
            fileName: fileName,
            isImage: file.type.startsWith('image/')
        }
      }));

      setTimeout(closeModal, 1500);

    } catch (error: any) {
      statusMessage!.textContent = `Error: ${error.message}`;
      statusMessage!.style.color = '#dc2626';
      progressFill!.style.backgroundColor = '#dc2626';
      submitBtn.disabled = false;
    }
  });
</script>
