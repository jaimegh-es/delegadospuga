import { db } from "../lib/firebase/server";

// Obtener exámenes de Firestore
let examenes = {};
try {
  const snapshot = await db.collection("calendar_events").where("type", "==", "exam").get();
  
  // Agrupar por fecha
      snapshot.docs.forEach(doc => {
      const data = doc.data();
      const fecha = data.date;
      
      if (!examenes[fecha]) {
        examenes[fecha] = [];
      }
      
      examenes[fecha].push({
        asignatura: data.subject,
        titulo: data.title || null,
        hora: data.time || "",
        aula: data.classroom || "B1B",
        detalles: data.details || ""
      });
    });} catch (error) {
  console.error("Error fetching exams:", error);
  // Fallback to empty or keep hardcoded as backup? Better empty to avoid confusion.
  examenes = {};
}

// Función para generar los días del mes
function generarDiasMes(año, mes) {
    const diasEnMes = new Date(año, mes, 0).getDate();
    const primerDia = new Date(año, mes - 1, 1).getDay();
    const espaciosVacios = primerDia === 0 ? 6 : primerDia - 1;

    const dias = [];

    // Días vacíos
    for (let i = 0; i < espaciosVacios; i++) {
        dias.push({ vacio: true });
    }

    // Días del mes
    for (let dia = 1; dia <= diasEnMes; dia++) {
        const fecha = `${año}-${mes.toString().padStart(2, "0")}-${dia.toString().padStart(2, "0")}`;
        const examen = examenes[fecha];

        dias.push({
            numero: dia,
            fecha: fecha,
            examen: examen || null,
            vacio: false,
        });
    }

    // Completar la última semana si es necesario
    while (dias.length % 7 !== 0) {
        dias.push({ vacio: true });
    }

    return dias;
}

// Generar calendarios para cada mes

const marzo = generarDiasMes(2026, 3);
const abril = generarDiasMes(2026, 4);
const mayo = generarDiasMes(2026, 5);
const junio = generarDiasMes(2026, 6);

// Función para dividir en semanas
function dividirEnSemanas(dias) {
    const semanas = [];
    for (let i = 0; i < dias.length; i += 7) {
        semanas.push(dias.slice(i, i + 7));
    }
    return semanas;
}

// Cálculo del progreso del curso
const cursoInicio = new Date("2025-09-11");
const cursoFin = new Date("2026-06-20");
const hoy = new Date();

const totalDias = Math.ceil((cursoFin.getTime() - cursoInicio.getTime()) / (1000 * 60 * 60 * 24));
const diasTranscurridos = Math.ceil((hoy.getTime() - cursoInicio.getTime()) / (1000 * 60 * 60 * 24));
const porcentajeProgreso = Math.max(0, Math.min(100, (diasTranscurridos / totalDias) * 100));

const totalCuadritos = 30;
const cuadritosRellenos = Math.floor((porcentajeProgreso / 100) * totalCuadritos);
