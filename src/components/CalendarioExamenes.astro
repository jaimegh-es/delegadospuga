        cursor: pointer;
        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease;
    }

    .dia.tiene-examen:hover {
        transform: scale(1.05);
        box-shadow: 0 8px 20px rgba(0, 30, 96, 0.3);
    }

    .numero-dia {
        position: absolute;
        top: 4px;
        left: 6px;
        font-weight: 600;
        font-size: 0.875rem;
        color: #374151;
    }

    .dia.tiene-examen .numero-dia {
        color: white;
    }

    .examen-info {
        position: absolute;
        bottom: 4px;
        left: 4px;
        right: 4px;
        text-align: center;
        font-size: 0.6rem;
        line-height: 1.1;
    }

    .examen-info .asignatura {
        font-weight: 700;
        margin-bottom: 2px;
        text-transform: uppercase;
    }

    .examen-info .hora {
        font-weight: 500;
        opacity: 0.9;
    }

    /* Modal Styles */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.6);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1000;
    }

    .modal-examenes .modal-content {
        background: white;
        padding: 40px !important;
        border-radius: 20px;
        width: 95%;
        max-width: 550px;
        position: relative;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
        animation: fadeIn 0.3s ease-out;
        box-sizing: border-box;
        max-height: 90vh;
        overflow-y: auto !important;
        overflow-x: hidden;
    }

    /* Asegurar que todo dentro use border-box */
    .modal-examenes .modal-content *,
    .modal-examenes .modal-content *::before,
    .modal-examenes .modal-content *::after {
        box-sizing: border-box;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: scale(0.95);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .modal-close {
        position: absolute;
        top: 15px;
        right: 15px;
        background: none;
        border: none;
        font-size: 1.8rem;
        cursor: pointer;
        color: #64748b;
    }

    #modal-fecha-titulo {
        font-size: 1.8rem;
        font-weight: 800;
        color: #2000ad;
        margin-bottom: 25px;
        padding-right: 30px; /* Espacio para el botón de cerrar */
        line-height: 1.2;
        word-wrap: break-word;
    }

    .examen-item {
        border-bottom: 1px solid #e2e8f0;
        padding: 15px 0;
    }
    .examen-item:last-child {
        border-bottom: none;
    }

    #modal-detalles {
        font-size: 1rem;
        line-height: 1.6;
        color: #374151;
    }

    /* Estilos para contenido HTML en detalles */
    .detalles-content {
        margin-top: 8px;
    }

    .detalles-html {
        margin-top: 8px;
        line-height: 1.8;
    }

    .detalles-html button,
    .detalles-html a.btn {
        background: linear-gradient(45deg, #2000ad, #003d99);
        color: white !important;
        border: none;
        padding: 12px 20px; /* Más padding para que parezca más botón */
        border-radius: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: inline-block;
        margin: 10px 0; /* Margen vertical para separar de otros elementos */
        text-decoration: none !important;
        font-size: 0.95rem;
        border-bottom: none !important;
        max-width: 100%; /* No se sale del contenedor */
        white-space: normal; /* Permite que el texto baje si es muy largo */
        text-align: center;
        box-shadow: 0 4px 15px rgba(32, 0, 173, 0.2);
    }

    .detalles-html button:hover,
    .detalles-html a.btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(32, 0, 173, 0.3);
        color: white !important;
        border-bottom: none !important;
    }

    .detalles-html a:not(.btn) {
        color: #2000ad;
        text-decoration: none;
        font-weight: 600;
        border-bottom: 2px solid transparent;
        transition: all 0.3s ease;
    }

    .detalles-html a:not(.btn):hover {
        color: #003d99;
        border-bottom-color: #003d99;
    }

    .detalles-html strong,
    .detalles-html b {
        color: #2000ad;
        font-weight: 700;
    }

    .detalles-html em,
    .detalles-html i {
        font-style: italic;
        color: #64748b;
    }

    .detalles-html ul,
    .detalles-html ol {
        margin: 8px 0;
        padding-left: 24px;
    }

    .detalles-html li {
        margin: 4px 0;
    }

    .detalles-html p {
        margin: 8px 0;
    }

    .detalles-html code {
        background: #f1f5f9;
        padding: 2px 6px;
        border-radius: 4px;
        font-family: "Courier New", monospace;
        font-size: 0.9em;
        color: #2000ad;
    }

    .detalles-html hr {
        border: none;
        border-top: 2px solid #e2e8f0;
        margin: 12px 0;
    }

    .help-modal .modal-content {
        max-width: 600px;
        background: white;
        padding: 40px;
        border-radius: 24px;
        position: relative;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }

    .help-modal h3 {
        font-size: 1.75rem;
        font-weight: 800;
        color: #2000ad;
        margin-bottom: 20px;
    }

    .help-content p {
        color: #475569;
        margin-bottom: 20px;
        line-height: 1.6;
    }

    .video-container {
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        background: #000;
        margin-bottom: 25px;
        aspect-ratio: 16/9;
        display: flex;
        align-items: center;
    }

    .modal-actions {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .settings-btn {
        width: 100%;
        justify-content: center;
        padding: 16px;
        font-size: 1rem;
    }

    .help-modal .copy-btn {
        width: 100%;
        justify-content: center;
        padding: 16px;
        background: #64748b;
        color: white;
        border: none;
        border-radius: 50px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
        font-size: 1rem;
    }

    .help-modal .copy-btn:hover {
        background: #475569;
        transform: translateY(-2px);
    }

    /* Responsive */
    @media (max-width: 1024px) {
        .meses-grid {
            grid-template-columns: 1fr;
            gap: 32px;
        }
    }

    @media (max-width: 768px) {
        .calendario-section {
            padding: 40px 0;
        }

        .section-title {
            font-size: 2rem;
        }

        .calendario-container {
            padding: 24px;
        }

        .mes {
            padding: 16px;
        }

        .calendario-tabla td {
            height: 60px;
        }

        .numero-dia {
            font-size: 0.75rem;
        }

        .examen-info {
            font-size: 0.5rem;
        }

        .examen-info .asignatura {
            margin-bottom: 1px;
        }
    }

    @media (max-width: 480px) {
        .calendario-tabla td {
            height: 50px;
        }

        .numero-dia {
            font-size: 0.7rem;
            top: 2px;
            left: 4px;
        }

        .examen-info {
            font-size: 0.45rem;
            bottom: 2px;
        }

        .calendario-tabla th {
            padding: 8px 4px;
            font-size: 0.75rem;
        }
    }
</style>

<script>
    import { jsPDF } from "jspdf";
    import autoTable from "jspdf-autotable";

    document.addEventListener("DOMContentLoaded", () => {
        const modal = document.getElementById("examen-modal");
        const modalClose = document.getElementById("modal-close");
        const modalFechaTitulo = document.getElementById("modal-fecha-titulo");
        const modalExamenesLista = document.getElementById(
            "modal-examenes-lista",
        );
        const exportBtn = document.getElementById("export-pdf-btn");

        const examenesDataElement = document.getElementById("examenes-data");
        const examenes = JSON.parse(examenesDataElement?.textContent || "{}");

        const subscribeBtn = document.getElementById("subscribe-dropdown-btn");
        const subscribeMenu = document.getElementById("subscribe-menu");
        
        subscribeBtn?.addEventListener("click", (e) => {
            e.stopPropagation();
            subscribeMenu?.classList.toggle("show");
        });

        document.addEventListener("click", (e) => {
            if (subscribeMenu?.classList.contains("show") && !subscribeMenu.contains(e.target as Node) && e.target !== subscribeBtn) {
                subscribeMenu.classList.remove("show");
            }
        });

        const menuLinks = subscribeMenu?.querySelectorAll('a');
        menuLinks?.forEach(link => {
            link.addEventListener('click', () => {
                subscribeMenu?.classList.remove("show");
            });
        });

        const copyLinkBtn = document.getElementById("copy-calendar-link-btn-dropdown");
        const googleCalendarBtn = document.getElementById("google-calendar-btn");
        const appleCalendarBtn = document.getElementById("apple-calendar-btn");
        
        const helpModal = document.getElementById("google-calendar-modal");
        const appleHelpModal = document.getElementById("apple-calendar-modal");
        
        const helpModalClose = document.getElementById("google-calendar-modal-close");
        const appleHelpModalClose = document.getElementById("apple-calendar-modal-close");
        
        const helpVideo = document.getElementById("help-video") as HTMLVideoElement;
        const copyHelpBtn = document.getElementById("copy-url-help-btn");
        const copyAppleHelpBtn = document.getElementById("copy-url-apple-btn");

        const calendarUrl = "https://1bach.vercel.app/api/exams.ics";

        googleCalendarBtn?.addEventListener("click", (e) => {
            e.stopPropagation();
            subscribeMenu?.classList.remove("show");
            helpModal!.style.display = "flex";
            helpVideo?.play().catch(err => console.log("Auto-play blocked:", err));
        });

        appleCalendarBtn?.addEventListener("click", (e) => {
            e.stopPropagation();
            subscribeMenu?.classList.remove("show");
            appleHelpModal!.style.display = "flex";
        });

        helpModalClose?.addEventListener("click", () => {
            helpModal!.style.display = "none";
            helpVideo?.pause();
        });

        appleHelpModalClose?.addEventListener("click", () => {
            appleHelpModal!.style.display = "none";
        });

        helpModal?.addEventListener("click", (e) => {
            if (e.target === helpModal) {
                helpModal.style.display = "none";
                helpVideo?.pause();
            }
        });

        appleHelpModal?.addEventListener("click", (e) => {
            if (e.target === appleHelpModal) {
                appleHelpModal.style.display = "none";
            }
        });

        const handleCopy = (btn: HTMLElement | null) => {
            if (!btn) return;
            navigator.clipboard.writeText(calendarUrl).then(() => {
                const originalText = btn.innerHTML;
                btn.innerHTML = '<i class="fa-solid fa-check"></i> ¡Copiado!';
                const originalBg = btn.style.background;
                btn.style.background = "#10b981";
                setTimeout(() => {
                    btn.innerHTML = originalText;
                    btn.style.background = originalBg;
                }, 2000);
            });
        };

        copyHelpBtn?.addEventListener("click", () => handleCopy(copyHelpBtn));
        copyAppleHelpBtn?.addEventListener("click", () => handleCopy(copyAppleHelpBtn));

        copyLinkBtn?.addEventListener("click", (e) => {
            e.stopPropagation();
            navigator.clipboard.writeText(calendarUrl).then(() => {
                const originalText = copyLinkBtn.innerHTML;
                copyLinkBtn.innerHTML = '<i class="fa-solid fa-check"></i> ¡Copiado!';
                setTimeout(() => {
                    copyLinkBtn.innerHTML = originalText;
                    subscribeMenu?.classList.remove("show");
                }, 1500);
            }).catch(err => {
                console.error('Error al copiar: ', err);
                alert("Error al copiar el enlace");
            });
        });

        exportBtn?.addEventListener("click", () => {
            try {
                const doc = new jsPDF();

                doc.setFontSize(18);
                doc.setTextColor(32, 0, 173);
                doc.text("Calendario de Exámenes - 1B Bach", 14, 20);

                doc.setFontSize(12);
                doc.setTextColor(100, 116, 139);
                doc.text("2º y 3º Trimestre - Curso 2025/2026", 14, 28);

                const tableRows = [];
                const fechasOrdenadas = Object.keys(examenes).sort();

                fechasOrdenadas.forEach((fecha) => {
                    const fechaFormateada = new Date(
                        fecha + "T00:00:00",
                    ).toLocaleDateString("es-ES", {
                        day: "2-digit",
                        month: "2-digit",
                        year: "numeric",
                    });

                    examenes[fecha].forEach((examen: any) => {
                        tableRows.push([
                            fechaFormateada,
                            examen.asignatura,
                            examen.hora || "No especificada",
                            examen.aula || "B1B",
                            examen.detalles || "-",
                        ]);
                    });
                });

                // Usamos la función autoTable directamente importada
                autoTable(doc, {
                    head: [["Fecha", "Asignatura", "Hora", "Aula", "Detalles"]],
                    body: tableRows,
                    startY: 35,
                    theme: "striped",
                    headStyles: { fillColor: [32, 0, 173] },
                    styles: { fontSize: 9, cellPadding: 3 },
                    columnStyles: {
                        0: { cellWidth: 25 },
                        1: { cellWidth: 40 },
                        2: { cellWidth: 25 },
                        3: { cellWidth: 20 },
                        4: { cellWidth: "auto" },
                    },
                });

                doc.save("examenes-1b-bach.pdf");
            } catch (error) {
                console.error("Error al generar PDF:", error);
                alert(
                    "Hubo un error al generar el PDF. Por favor, inténtalo de nuevo.",
                );
            }
        });

        document.querySelectorAll(".tiene-examen").forEach((celda) => {
            celda.addEventListener("click", () => {
                const fecha = (celda as HTMLElement).dataset.examenFecha;
                if (fecha && examenes[fecha] && examenes[fecha].length > 0) {
                    const examenesDelDia = examenes[fecha];
                    modalFechaTitulo!.textContent = new Date(
                        fecha + "T00:00:00",
                    ).toLocaleDateString("es-ES", {
                        day: "numeric",
                        month: "long",
                        year: "numeric",
                    });
                    modalExamenesLista!.innerHTML = "";

                    examenesDelDia.forEach((examen: any) => {
                        const examenDiv = document.createElement("div");
                        examenDiv.classList.add("examen-item");

                        // Crear elementos individuales
                        const titulo = document.createElement("h4");
                        titulo.textContent = examen.titulo || examen.asignatura;

                        if (examen.titulo && examen.asignatura) {
                            const sub = document.createElement("p");
                            sub.style.fontSize = "0.9rem";
                            sub.style.color = "#64748b";
                            sub.style.marginTop = "-8px";
                            sub.style.marginBottom = "8px";
                            sub.innerHTML = `<strong>Asignatura:</strong> ${examen.asignatura}`;
                            examenDiv.appendChild(titulo);
                            examenDiv.appendChild(sub);
                        } else {
                            examenDiv.appendChild(titulo);
                        }

                        const horaP = document.createElement("p");
                        horaP.innerHTML = `<strong>Hora:</strong> ${examen.hora || "No especificada"}`;

                        const aulaP = document.createElement("p");
                        aulaP.innerHTML = `<strong>Aula:</strong> ${examen.aula || "No especificada"}`;

                        const detallesP = document.createElement("div");
                        detallesP.classList.add("detalles-content");
                        detallesP.innerHTML = `<strong>Detalles:</strong><div class="detalles-html">${examen.detalles || "No hay detalles adicionales."}</div>`;

                        examenDiv.appendChild(titulo);
                        examenDiv.appendChild(horaP);
                        examenDiv.appendChild(aulaP);
                        examenDiv.appendChild(detallesP);

                        modalExamenesLista!.appendChild(examenDiv);
                    });

                    modal!.style.display = "flex";
                }
            });
        });

        function closeModal() {
            modal!.style.display = "none";
        }

        modalClose?.addEventListener("click", closeModal);
        modal?.addEventListener("click", (e) => {
            if (e.target === modal) {
                closeModal();
            }
        });

        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape") {
                closeModal();
            }
        });
    });
</script>
