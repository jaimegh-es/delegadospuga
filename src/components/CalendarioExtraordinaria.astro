---

<section class="extraordinaria-section" id="extraordinaria">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Convocatoria Extraordinaria</h2>
            <p class="section-subtitle">Para los que suspendieran - 1ºBach</p>
        </div>

        <div class="calendario-card">
            <div class="table-responsive">
                <table class="extraordinaria-table">
                    <thead>
                        <tr>
                            <th>Horario</th>
                            <th>Martes 16 de Xuño</th>
                            <th>Mércores 17 de Xuño</th>
                            <th>Xoves 18 de Xuño</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="time-slot">09:00 - 10:30</td>
                            <td>
                                <div class="subject-item"><span class="subject">Bioloxía</span> <span class="room">Aula B1ºA</span></div>
                                <div class="subject-item"><span class="subject">Latín</span> <span class="room">Aula B1ºB</span></div>
                                <div class="subject-item"><span class="subject">Tec. e Enxeñería</span> <span class="room">Aula Tecnoloxía</span></div>
                            </td>
                            <td>
                                <div class="subject-item"><span class="subject">Matemáticas</span> <span class="room">Aula B1ºA</span></div>
                                <div class="subject-item"><span class="subject">Matemáticas CCSS</span> <span class="room">Aula B1ºB</span></div>
                            </td>
                            <td>
                                <div class="subject-item"><span class="subject">Física e Química</span> <span class="room">Aula B1ºA</span></div>
                                <div class="subject-item"><span class="subject">Economía</span> <span class="room">Aula B1ºB</span></div>
                                <div class="subject-item"><span class="subject">Lite. Universal</span> <span class="room">Aula B1ºC</span></div>
                            </td>
                        </tr>
                        <tr>
                            <td class="time-slot">11:00 - 12:30</td>
                            <td>
                                <div class="subject-item"><span class="subject">Lingua Castelá</span> <span class="room">Aula B1ºB</span></div>
                            </td>
                            <td>
                                <div class="subject-item"><span class="subject">Lingua Galega</span> <span class="room">Aula B1ºA</span></div>
                            </td>
                            <td>
                                <div class="subject-item"><span class="subject">Historia</span> <span class="room">Aula B1ºB</span></div>
                            </td>
                        </tr>
                        <tr>
                            <td class="time-slot">13:00 - 14:30</td>
                            <td>
                                <div class="subject-item"><span class="subject">Filosofía I</span> <span class="room">Aula B1ºA</span></div>
                            </td>
                            <td>
                                <div class="subject-item"><span class="subject">Lingua Inglesa</span> <span class="room">Aula B1ºB</span></div>
                            </td>
                            <td>
                                <div class="subject-item"><span class="subject">TIC</span> <span class="room">Aula Informática</span></div>
                                <div class="subject-item"><span class="subject">Francés</span> <span class="room">Aula B1ºB</span></div>
                                <div class="subject-item"><span class="subject">Debuxo</span> <span class="room">Aula Debuxo</span></div>
                                <div class="subject-item"><span class="subject">Tec. Intelixentes</span> <span class="room">Aula Esther</span></div>
                            </td>
                        </tr>
                        <tr>
                            <td class="time-slot">16:30 - 18:00</td>
                            <td>
                                <div class="subject-item"><span class="subject">Educación Física</span> <span class="room">Pavillón</span></div>
                            </td>
                            <td class="empty-slot"></td>
                            <td class="empty-slot"></td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Mobile View -->
            <div class="mobile-grid">
                <div class="day-card">
                    <h3 class="day-title">Martes 16 de Xuño</h3>
                    <div class="mobile-items">
                        <div class="mobile-item">
                            <span class="m-time">09:00-10:30</span>
                            <div class="m-subs">
                                <p>Bioloxía (B1ºA), Latín (B1ºB), Tec. e Enxeñería (Tecno)</p>
                            </div>
                        </div>
                        <div class="mobile-item">
                            <span class="m-time">11:00-12:30</span>
                            <div class="m-subs"><p>Lingua Castelá (B1ºB)</p></div>
                        </div>
                        <div class="mobile-item">
                            <span class="m-time">13:00-14:30</span>
                            <div class="m-subs"><p>Filosofía I (B1ºA)</p></div>
                        </div>
                        <div class="mobile-item">
                            <span class="m-time">16:30-18:00</span>
                            <div class="m-subs"><p>Educación Física (Pavillón)</p></div>
                        </div>
                    </div>
                </div>

                <div class="day-card">
                    <h3 class="day-title">Mércores 17 de Xuño</h3>
                    <div class="mobile-items">
                        <div class="mobile-item">
                            <span class="m-time">09:00-10:30</span>
                            <div class="m-subs">
                                <p>Matemáticas (B1ºA), Matemáticas CCSS (B1ºB)</p>
                            </div>
                        </div>
                        <div class="mobile-item">
                            <span class="m-time">11:00-12:30</span>
                            <div class="m-subs"><p>Lingua Galega (B1ºA)</p></div>
                        </div>
                        <div class="mobile-item">
                            <span class="m-time">13:00-14:30</span>
                            <div class="m-subs"><p>Lingua Inglesa (B1ºB)</p></div>
                        </div>
                    </div>
                </div>

                <div class="day-card">
                    <h3 class="day-title">Xoves 18 de Xuño</h3>
                    <div class="mobile-items">
                        <div class="mobile-item">
                            <span class="m-time">09:00-10:30</span>
                            <div class="m-subs">
                                <p>Física e Química (B1ºA), Economía (B1ºB), Lite. Universal (B1ºC)</p>
                            </div>
                        </div>
                        <div class="mobile-item">
                            <span class="m-time">11:00-12:30</span>
                            <div class="m-subs"><p>Historia (B1ºB)</p></div>
                        </div>
                        <div class="mobile-item">
                            <span class="m-time">13:00-14:30</span>
                            <div class="m-subs">
                                <p>TIC (Info), Francés (B1ºB), Debuxo (Debuxo), Tec. Intelixentes (Esther)</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .extraordinaria-section {
        padding: 80px 0;
        background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px;
    }

    .section-header {
        text-align: center;
        margin-bottom: 50px;
    }

    .section-title {
        font-size: 2.5rem;
        font-weight: 800;
        color: #2000ad;
        margin-bottom: 10px;
        font-family: 'Oswald', sans-serif;
        text-transform: uppercase;
        letter-spacing: -0.02em;
    }

    .section-subtitle {
        font-size: 1.1rem;
        color: #64748b;
        font-weight: 500;
    }

    .calendario-card {
        background: white;
        border-radius: 30px;
        padding: 40px;
        box-shadow: 0 20px 50px rgba(32, 0, 173, 0.1);
        border: 1px solid rgba(32, 0, 173, 0.05);
    }

    .table-responsive {
        display: block;
    }

    .extraordinaria-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
    }

    .extraordinaria-table th {
        background: #2000ad;
        color: white;
        padding: 20px;
        text-align: left;
        font-weight: 700;
        font-family: 'Oswald', sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .extraordinaria-table td {
        padding: 20px;
        border-bottom: 1px solid #e2e8f0;
        border-right: 1px solid #e2e8f0;
        vertical-align: top;
        background: white;
    }

    .extraordinaria-table td:last-child {
        border-right: none;
    }

    .extraordinaria-table tr:last-child td {
        border-bottom: none;
    }

    .time-slot {
        background: #f8fafc !important;
        font-weight: 800;
        color: #2000ad;
        width: 180px;
        white-space: nowrap;
        font-family: 'Inter', sans-serif;
    }

    .subject-item {
        margin-bottom: 12px;
        display: flex;
        flex-direction: column;
    }

    .subject-item:last-child {
        margin-bottom: 0;
    }

    .subject {
        font-weight: 700;
        color: #1e293b;
        font-size: 1rem;
    }

    .room {
        font-size: 0.85rem;
        color: #64748b;
        font-weight: 500;
    }

    .empty-slot {
        background: #f1f5f9 !important;
    }

    /* Mobile styles */
    .mobile-grid {
        display: none;
        flex-direction: column;
        gap: 20px;
    }

    .day-card {
        background: #f8fafc;
        border-radius: 20px;
        padding: 20px;
        border: 1px solid #e2e8f0;
    }

    .day-title {
        color: #2000ad;
        font-weight: 800;
        font-family: 'Oswald', sans-serif;
        text-transform: uppercase;
        margin-bottom: 15px;
        font-size: 1.2rem;
        border-bottom: 2px solid #2000ad;
        padding-bottom: 5px;
        display: inline-block;
    }

    .mobile-item {
        margin-bottom: 15px;
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .m-time {
        font-weight: 800;
        color: #2000ad;
        font-size: 0.9rem;
        background: rgba(32, 0, 173, 0.1);
        padding: 2px 10px;
        border-radius: 5px;
        width: fit-content;
    }

    .m-subs p {
        font-size: 1rem;
        color: #1e293b;
        font-weight: 600;
    }

    @media (max-width: 992px) {
        .table-responsive {
            display: none;
        }
        .mobile-grid {
            display: flex;
        }
        .calendario-card {
            padding: 20px;
            border-radius: 24px;
        }
        .section-title {
            font-size: 2rem;
        }
    }
</style>
