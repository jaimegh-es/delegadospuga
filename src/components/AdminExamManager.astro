    async function importLegacyExams() {
        const confirmed = await (window as any).showConfirm("¿Estás seguro de importar los exámenes antiguos?");
        if (!confirmed) return;
        const button = document.getElementById('import-legacy-btn');
        (button as HTMLButtonElement).disabled = true;
        
        (window as any).showLoading();
        
        try {
            for (const [date, exams] of Object.entries(legacyExams)) {
                for (const exam of exams as any[]) {
                    await fetch('/api/calendar', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            type: 'exam', date, subject: exam.asignatura, classroom: exam.aula, details: exam.detalles, time: exam.hora
                        })
                    });
                }
            }
            (window as any).showAlert("Exámenes importados correctamente.", "success");
            await loadExams();
        } catch (e) {
            (window as any).showAlert("Error al importar.", "error");
        } finally {
            (button as HTMLButtonElement).disabled = false;
            (window as any).hideLoading();
        }
    }
document.addEventListener('DOMContentLoaded', async () => {
    (window as any).showLoading();
    initTipTap();
    await loadExams();
    loadDraft();

    // Auto-save cada 10 segundos
    setInterval(saveDraft, 10000);

    document.getElementById('exam-form')?.addEventListener('submit', handleFormSubmit);
    document.getElementById('cancel-exam-edit')?.addEventListener('click', resetExamsForm);

    // Guardar al cambiar campos
    document.querySelectorAll('#exam-form input, #exam-form select, #exam-form textarea').forEach(el => {
        el.addEventListener('change', saveDraft);
    });

    document.getElementById('prev-month-exams')?.addEventListener('click', async () => { 
            (window as any).showLoading();
            currentDate.setMonth(currentDate.getMonth() - 1); 
            renderCalendar(); 
            (window as any).hideLoading();
        });
        document.getElementById('next-month-exams')?.addEventListener('click', async () => { 
            (window as any).showLoading();
            currentDate.setMonth(currentDate.getMonth() + 1); 
            renderCalendar(); 
            (window as any).hideLoading();
        });
        document.getElementById('import-legacy-btn')?.addEventListener('click', importLegacyExams);

        document.getElementById('bar-edit-btn-exams')?.addEventListener('click', () => {
            if (selectedId) (window as any).editExamItem(selectedId);
        });
        document.getElementById('bar-delete-btn-exams')?.addEventListener('click', () => {
            if (selectedId) deleteExamItem(selectedId);
        });
        document.getElementById('bar-close-btn-exams')?.addEventListener('click', closeMobileActionBar);
        document.getElementById('close-selection-modal-exams')?.addEventListener('click', closeSelectionModal);
        
        (window as any).hideLoading();
    });
