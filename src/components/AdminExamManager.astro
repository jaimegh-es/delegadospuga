<script>
    import { Editor } from '@tiptap/core';
    import StarterKit from '@tiptap/starter-kit';
    import Link from '@tiptap/extension-link';
    import Image from '@tiptap/extension-image';
    import Placeholder from '@tiptap/extension-placeholder';
    import Underline from '@tiptap/extension-underline';

    let currentDate = new Date();
    let eventsData = [];
    let tiptapExams;

    function initTipTap() {
        tiptapExams = new Editor({
            element: document.querySelector('#editor-exams'),
            extensions: [
                StarterKit,
                Underline,
                Link.configure({
                    openOnClick: false,
                    HTMLAttributes: {
                        class: null,
                    },
                }),
                Image,
                Placeholder.configure({
                    placeholder: 'Detalles del examen...',
                }),
            ],
            content: '',
            onUpdate: ({ editor }) => {
                const html = editor.getHTML();
                (document.getElementById('hidden-details-exams') as HTMLInputElement).value = html;
                updateToolbarState();
            },
            onSelectionUpdate: () => {
                updateToolbarState();
            }
        });

        setupToolbarListeners();
        setupUploadListeners();
    }

    function setupUploadListeners() {
        // Botón imagen editor
        document.getElementById('upload-exam-img-btn')?.addEventListener('click', () => {
            saveDraft();
            window.dispatchEvent(new CustomEvent('open-upload-modal', { detail: { mode: 'exam-image' } }));
        });

        // Botón archivo editor
        document.getElementById('upload-exam-file-btn')?.addEventListener('click', () => {
            saveDraft();
            window.dispatchEvent(new CustomEvent('open-upload-modal', { detail: { mode: 'exam-file' } }));
        });

        // Escuchar evento de subida completada
        window.addEventListener('file-uploaded', (async (e: any) => {
            const { url, mode, fileName, isImage } = e.detail;
            
            if (mode === 'exam-image') {
                tiptapExams.chain().focus().setImage({ src: url, alt: fileName }).run();
                (window as any).showAlert("Imagen insertada en el examen", "success");
            } else if (mode === 'exam-file') {
                const linkText = await (window as any).showPrompt('Texto para el enlace del archivo:', fileName);
                if (linkText) {
                    tiptapExams.chain().focus().insertContent(`<a href="${url}" target="_blank" class="file-link"><i class="fas fa-paperclip"></i> ${linkText}</a>`).run();
                    (window as any).showAlert("Archivo enlazado en el examen", "success");
                }
            }
            saveDraft();
        }) as any);
    }

    // --- SISTEMA DE BORRADOR (AUTO-SAVE) ---
    function saveDraft() {
        if (!tiptapExams) return;
        const draft = {
            id: (document.getElementById('exam-id') as HTMLInputElement).value,
            date: (document.getElementById('exam-date') as HTMLInputElement).value,
            subject: (document.getElementById('exam-subject') as HTMLSelectElement).value,
            title: (document.getElementById('exam-title') as HTMLInputElement).value,
            time: (document.getElementById('exam-time') as HTMLInputElement).value,
            classroom: (document.getElementById('exam-classroom') as HTMLInputElement).value,
            content: tiptapExams.getHTML(),
            timestamp: Date.now()
        };
        if (draft.subject || draft.content.length > 7) {
            localStorage.setItem('exam_admin_draft', JSON.stringify(draft));
        }
    }

    function loadDraft() {
        const raw = localStorage.getItem('exam_admin_draft');
        if (!raw) return;
        
        try {
            const draft = JSON.parse(raw);
            if (Date.now() - draft.timestamp > 86400000) return;
            if (!draft.subject && draft.content.length <= 7) return;

            const confirmLoad = confirm("He encontrado un borrador de examen sin guardar. ¿Restaurar?");
            if (!confirmLoad) {
                localStorage.removeItem('exam_admin_draft');
                return;
            }

            (document.getElementById('exam-id') as HTMLInputElement).value = draft.id || '';
            (document.getElementById('exam-date') as HTMLInputElement).value = draft.date || '';
            (document.getElementById('exam-subject') as HTMLSelectElement).value = draft.subject || '';
            (document.getElementById('exam-title') as HTMLInputElement).value = draft.title || '';
            (document.getElementById('exam-time') as HTMLInputElement).value = draft.time || '';
            (document.getElementById('exam-classroom') as HTMLInputElement).value = draft.classroom || 'B1B';
            
            if (tiptapExams && draft.content) {
                tiptapExams.commands.setContent(draft.content);
            }

            if (draft.id) {
                document.getElementById('exam-form-title').textContent = "Editar Examen (Borrador)";
                document.getElementById('exam-submit-btn').textContent = "Actualizar Examen";
                document.getElementById('cancel-exam-edit').classList.remove('hidden');
            }
            
            (window as any).showAlert("Borrador de examen restaurado", "success");
        } catch (e) {
            console.error("Error loading exam draft", e);
        }
    }

    function clearDraft() {
        localStorage.removeItem('exam_admin_draft');
    }

    function setupToolbarListeners() {
        const toolbar = document.getElementById('toolbar-exams');
        if (!toolbar) return;

        toolbar.querySelectorAll('button').forEach(btn => {
            btn.addEventListener('click', async (e) => {
                e.preventDefault();
                const action = btn.dataset.action;
                
                switch(action) {
                    case 'bold': tiptapExams.chain().focus().toggleBold().run(); break;
                    case 'italic': tiptapExams.chain().focus().toggleItalic().run(); break;
                    case 'underline': tiptapExams.chain().focus().toggleUnderline().run(); break;
                    case 'h2': tiptapExams.chain().focus().toggleHeading({ level: 2 }).run(); break;
                    case 'h3': tiptapExams.chain().focus().toggleHeading({ level: 3 }).run(); break;
                    case 'bulletList': tiptapExams.chain().focus().toggleBulletList().run(); break;
                    case 'orderedList': tiptapExams.chain().focus().toggleOrderedList().run(); break;
                    case 'undo': tiptapExams.chain().focus().undo().run(); break;
                    case 'redo': tiptapExams.chain().focus().redo().run(); break;
                    case 'link': 
                        const url = await (window as any).showPrompt('URL del enlace:');
                        if (url) tiptapExams.chain().focus().setLink({ href: url }).run();
                        break;
                    case 'unlink': tiptapExams.chain().focus().unsetLink().run(); break;
                    case 'btnLink':
                        const btnUrl = await (window as any).showPrompt('URL del botón:');
                        const btnText = await (window as any).showPrompt('Texto del botón:', 'Descargar material');
                        if (btnUrl && btnText) {
                            tiptapExams.chain().focus().insertContent(`<a href="${btnUrl}" class="btn-link">${btnText}</a>`).run();
                        }
                        break;
                }
                updateToolbarState();
            });
        });
    }

    function updateToolbarState() {
        const toolbar = document.getElementById('toolbar-exams');
        if (!toolbar || !tiptapExams) return;

        toolbar.querySelectorAll('button').forEach(btn => {
            const action = btn.dataset.action;
            let isActive = false;

            if (['bold', 'italic', 'underline', 'bulletList', 'orderedList'].includes(action)) {
                isActive = tiptapExams.isActive(action);
            } else if (['h2', 'h3'].includes(action)) {
                const level = parseInt(action.replace('h', ''));
                isActive = tiptapExams.isActive('heading', { level });
            }

            if (isActive) btn.classList.add('active');
            else btn.classList.remove('active');
        });
    }

    async function loadExams() {
        try {
            const res = await fetch('/api/calendar');
            const allData = await res.json();
            eventsData = allData.filter(e => e.type === 'exam');
            renderCalendar();
        } catch (e) {
            console.error("Error loading exams", e);
        }
    }

    function renderCalendar() {
        const tbody = document.getElementById('admin-exam-calendar-body');
        const monthDisplay = document.getElementById('current-month-display-exams');
        
        if (!tbody || !monthDisplay) return;

        const year = currentDate.getFullYear();
        const month = currentDate.getMonth();

        monthDisplay.textContent = new Date(year, month).toLocaleDateString('es-ES', { month: 'long', year: 'numeric' });

        const daysInMonth = new Date(year, month + 1, 0).getDate();
        const firstDay = new Date(year, month, 1).getDay();
        const adjustedFirstDay = firstDay === 0 ? 6 : firstDay - 1;

        tbody.innerHTML = '';
        
        let currentDay = 1;
        let row = document.createElement('tr');
        let dayCount = 0;

        for (let i = 0; i < adjustedFirstDay; i++) {
            const cell = document.createElement('td');
            cell.className = 'dia-vacio';
            row.appendChild(cell);
            dayCount++;
        }

        while (currentDay <= daysInMonth) {
            if (dayCount === 7) {
                tbody.appendChild(row);
                row = document.createElement('tr');
                dayCount = 0;
            }

            const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(currentDay).padStart(2, '0')}`;
            const dayExams = eventsData.filter(e => e.date === dateStr);
            const hasExam = dayExams.length > 0;
            
            const cell = document.createElement('td');
            cell.className = hasExam ? 'dia tiene-examen' : 'dia';
            cell.dataset.date = dateStr;
            
            cell.addEventListener('click', () => handleDayClick(dateStr));

            let content = `<div class="numero-dia">${currentDay}</div>`;
            
            if (hasExam) {
                 content += `<div class="examen-info">`;
                 dayExams.slice(0, 2).forEach(ev => {
                     content += `<div class="asignatura">${ev.title || ev.subject}</div>`;
                 });
                 if (dayExams.length > 2) content += `<div class="asignatura">+${dayExams.length - 2}</div>`;
                 content += `</div>`;
            }

            cell.innerHTML = content;
            row.appendChild(cell);
            currentDay++;
            dayCount++;
        }

        while (dayCount < 7 && dayCount > 0) {
            const cell = document.createElement('td');
            cell.className = 'dia-vacio';
            row.appendChild(cell);
            dayCount++;
        }
        if (row.children.length > 0) tbody.appendChild(row);
    }

    let selectedId = null;
    const mobileBar = document.getElementById('mobile-action-bar-exams');
    const selectionModal = document.getElementById('selection-modal-exams');
    const selectionList = document.getElementById('selection-list-exams');

    function handleDayClick(dateStr) {
        const dayExams = eventsData.filter(e => e.date === dateStr);
        if (dayExams.length === 0) {
            closeMobileActionBar();
            return;
        }

        if (dayExams.length === 1) {
            selectItem(dayExams[0].id);
        } else {
            showSelectionList(dayExams);
        }
    }

    function showSelectionList(exams) {
        selectionList.innerHTML = '';
        exams.forEach(ex => {
            const item = document.createElement('div');
            item.className = 'selection-item';
            item.innerHTML = `
                <span class="item-title">${ex.title || 'Sin título'}</span>
                <span class="item-subject">${ex.subject}</span>
                <span class="item-time">${ex.time || 'Sin hora'}</span>
            `;
            item.onclick = () => {
                selectItem(ex.id);
                closeSelectionModal();
            };
            selectionList.appendChild(item);
        });
        selectionModal.classList.remove('hidden');
    }

    function closeSelectionModal() {
        selectionModal.classList.add('hidden');
    }

    function selectItem(id) {
        selectedId = id;
        const item = eventsData.find(e => e.id === id);
        if (!item) return;

        document.getElementById('selected-item-name').textContent = item.title || item.subject;
        mobileBar.classList.add('active');

        // Highlight in calendar
        document.querySelectorAll('.dia').forEach(d => d.classList.remove('selected'));
        const cell = document.querySelector(`td[data-date="${item.date}"]`);
        if (cell) cell.classList.add('selected');
    }

    function closeMobileActionBar() {
        mobileBar.classList.remove('active');
        selectedId = null;
        document.querySelectorAll('.dia').forEach(d => d.classList.remove('selected'));
    }

    (window as any).editExamItem = (id) => {
        (window as any).showLoading();
        
        setTimeout(() => {
            const item = eventsData.find(e => e.id === id);
            if (!item) {
                (window as any).hideLoading();
                return;
            }

            (document.getElementById('exam-id') as HTMLInputElement).value = item.id;
            (document.getElementById('exam-date') as HTMLInputElement).value = item.date;
            (document.getElementById('exam-subject') as HTMLSelectElement).value = item.subject;
            (document.getElementById('exam-title') as HTMLInputElement).value = item.title || '';
            (document.getElementById('exam-time') as HTMLInputElement).value = item.time || '';
            (document.getElementById('exam-classroom') as HTMLInputElement).value = item.classroom || 'B1B';
            tiptapExams.commands.setContent(item.details || '');
            
            document.getElementById('exam-form-title').textContent = "Editar Examen";
            document.getElementById('exam-submit-btn').textContent = "Actualizar Examen";
            document.getElementById('cancel-exam-edit').classList.remove('hidden');
            
            window.scrollTo({ top: document.getElementById('exam-manager-content').offsetTop - 100, behavior: 'smooth' });
            closeMobileActionBar();
            
            (window as any).hideLoading();
        }, 300);
    };

    function resetExamsForm() {
        (window as any).showLoading();
        
        setTimeout(() => {
            const form = document.getElementById('exam-form') as HTMLFormElement;
            form.reset();
            (document.getElementById('exam-id') as HTMLInputElement).value = '';
            (document.getElementById('exam-title') as HTMLInputElement).value = '';
            tiptapExams.commands.setContent('');
            document.getElementById('exam-form-title').textContent = "Añadir Examen";
            document.getElementById('exam-submit-btn').textContent = "Añadir Examen";
            document.getElementById('cancel-exam-edit').classList.add('hidden');
            
            clearDraft();
            (window as any).hideLoading();
        }, 300);
    }

    async function deleteExamItem(id) {
        const confirmed = await (window as any).showConfirm("¿Borrar este examen?");
        if (!confirmed) return;

        (window as any).showLoading();
        try {
            const res = await fetch('/api/calendar', {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id })
            });

            if (res.ok) {
                closeMobileActionBar();
                await loadExams();
                (window as any).showAlert("Examen borrado correctamente", "success");
            } else {
                (window as any).showAlert("Error al borrar", "error");
            }
        } catch (e) {
            (window as any).showAlert("Error de conexión", "error");
        } finally {
            (window as any).hideLoading();
        }
    }
    (window as any).deleteExamItem = deleteExamItem;

    async function handleFormSubmit(e) {
        e.preventDefault();
        const form = e.target;
        
        (window as any).showLoading();
        
        (document.getElementById('hidden-details-exams') as HTMLInputElement).value = tiptapExams.getHTML();

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        
        try {
            const res = await fetch('/api/calendar', {
                method: data.id ? 'PATCH' : 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            if (res.ok) {
                resetExamsForm();
                await loadExams();
                clearDraft();
                (window as any).showAlert("Examen guardado correctamente", "success");

                // Preguntar para Telegram
                const publishInTelegram = await (window as any).showConfirm("¿Quieres avisar de este examen en Telegram también?");
                if (publishInTelegram) {
                    (window as any).showLoading();
                    try {
                        await fetch('/api/telegram', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                title: `📅 NUEVO EXAMEN: ${data.subject}`,
                                subtitle: `Fecha: ${new Date(data.date as string).toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long' })}${data.time ? ` a las ${data.time}` : ''}\nAsignatura: ${data.subject}${data.title ? ` (${data.title})` : ''}\nAula: ${data.classroom || 'B1B'}`,
                            })
                        });
                        (window as any).showAlert("Aviso enviado a Telegram", "success");
                    } catch (e) {
                        (window as any).showAlert("Error enviando a Telegram", "error");
                    } finally {
                        (window as any).hideLoading();
                    }
                }
            } else {
                (window as any).showAlert("Error al guardar", "error");
            }
        } catch (e) {
            alert("Error de conexión");
        } finally {
            (window as any).hideLoading();
        }
    }

