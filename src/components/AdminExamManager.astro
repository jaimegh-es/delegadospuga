<div class="admin-card">
    <h3>Gestión de Exámenes</h3>

    <!-- Formulario Exámenes -->
    <div id="exam-manager-content">
        <h4 id="exam-form-title" class="form-title">Añadir Examen</h4>
        <form id="exam-form" class="event-form">
            <input type="hidden" name="id" id="exam-id">
            <input type="hidden" name="type" value="exam">
            
            <div class="form-group">
                <label>Fecha:</label>
                <input type="date" name="date" id="exam-date" required>
            </div>

            <div class="form-group">
                <label>Asignatura:</label>
                <select name="subject" id="exam-subject" required>
                    <option value="">Selecciona una asignatura</option>
                    <option value="Lengua">Lengua</option>
                    <option value="Gallego">Gallego</option>
                    <option value="Inglés">Inglés</option>
                    <option value="Matemáticas">Matemáticas</option>
                    <option value="Física y Química">Física y Química</option>
                    <option value="Biología">Biología</option>
                    <option value="Historia">Historia</option>
                    <option value="Filosofía">Filosofía</option>
                    <option value="Educación Física">Educación Física</option>
                    <option value="Religión/Valores">Religión/Valores</option>
                    <option value="TIC">TIC</option>
                    <option value="Economía">Economía</option>
                    <option value="Cultura Clásica">Cultura Clásica</option>
                    <option value="Dibujo Técnico">Dibujo Técnico</option>
                    <option value="Latín">Latín</option>
                    <option value="Griego">Griego</option>
                    <option value="Francés">Francés</option>
                </select>
            </div>

            <div class="form-group">
                <label>Nombre personalizado (Opcional):</label>
                <input type="text" name="title" id="exam-title" placeholder="Ej: Recuperación, Parcial...">
            </div>

            <div class="form-group">
                <label>Hora (Opcional):</label>
                <input type="text" name="time" id="exam-time" placeholder="Ej: 08:30">
            </div>

            <div class="form-group">
                <label>Aula (Opcional):</label>
                <input type="text" name="classroom" id="exam-classroom" placeholder="Ej: B1B" value="B1B">
            </div>

            <div class="form-group full-width">
                <label>Detalles:</label>
                <div class="tiptap-container">
                    <div id="toolbar-exams" class="tiptap-toolbar">
                        <div class="toolbar-group">
                            <button type="button" data-action="bold" title="Negrita"><i class="fas fa-bold"></i></button>
                            <button type="button" data-action="italic" title="Cursiva"><i class="fas fa-italic"></i></button>
                            <button type="button" data-action="underline" title="Subrayado"><i class="fas fa-underline"></i></button>
                        </div>
                        <div class="toolbar-group">
                            <button type="button" data-action="h2" title="Título 2">H2</button>
                            <button type="button" data-action="h3" title="Título 3">H3</button>
                        </div>
                        <div class="toolbar-group">
                            <button type="button" data-action="bulletList" title="Lista Viñetas"><i class="fas fa-list-ul"></i></button>
                            <button type="button" data-action="orderedList" title="Lista Numerada"><i class="fas fa-list-ol"></i></button>
                        </div>
                        <div class="toolbar-group">
                            <button type="button" data-action="link" title="Enlace"><i class="fas fa-link"></i></button>
                            <button type="button" data-action="unlink" title="Quitar Enlace"><i class="fas fa-unlink"></i></button>
                            <button type="button" id="upload-exam-file-btn" title="Subir y Enlazar Archivo"><i class="fas fa-file-upload"></i></button>
                            <button type="button" id="upload-exam-img-btn" title="Subir e Insertar Imagen"><i class="fas fa-image"></i></button>
                            <button type="button" data-action="btnLink" title="Añadir Botón" class="btn-toolbar-special"><i class="fas fa-external-link-alt"></i> Botón</button>
                        </div>
                        <div class="toolbar-group">
                            <button type="button" data-action="undo" title="Deshacer"><i class="fas fa-undo"></i></button>
                            <button type="button" data-action="redo" title="Rehacer"><i class="fas fa-redo"></i></button>
                        </div>
                    </div>
                    <div id="editor-exams" class="tiptap-editor"></div>
                </div>
                <input type="hidden" name="details" id="hidden-details-exams">
            </div>

            <div class="form-actions">
                <button type="button" id="cancel-exam-edit" class="secondary-btn hidden">Cancelar Edición</button>
                <button type="submit" class="submit-btn" id="exam-submit-btn">Añadir Examen</button>
            </div>
        </form>
    </div>

    <!-- Vista Calendario -->
    <div class="calendar-preview-section">
        <div class="section-header-preview">
            <h4>Vista Previa Exámenes</h4>
            <p class="hint-preview">Pasa el ratón para editar o borrar</p>
        </div>
        
        <div class="month-controls">
            <button id="prev-month-exams">&lt;</button>
            <h3 id="current-month-display-exams" class="mes-titulo"></h3>
            <button id="next-month-exams">&gt;</button>
        </div>
        
        <div class="mes-container">
            <div class="mes">
                <table class="calendario-tabla">
                    <thead>
                        <tr>
                            <th>L</th>
                            <th>M</th>
                            <th>X</th>
                            <th>J</th>
                            <th>V</th>
                            <th>S</th>
                            <th>D</th>
                        </tr>
                    </thead>
                    <tbody id="admin-exam-calendar-body">
                        <!-- Filled by JS -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Maintenance Section -->
    <div class="maintenance-section">
        <h4>Mantenimiento</h4>
        <button id="import-legacy-btn" class="secondary-btn">Importar Exámenes Anteriores</button>
        <p class="hint">Usar solo una vez para cargar los exámenes antiguos.</p>
    </div>

    <!-- Bottom Bar for Actions -->
    <div id="mobile-action-bar-exams" class="bottom-action-bar">
        <div class="selected-info">
            <span id="selected-item-name"></span>
        </div>
        <div class="action-buttons">
            <button id="bar-edit-btn-exams" class="bar-edit-btn">
                <i class="fa-solid fa-pen-to-square"></i> Editar
            </button>
            <button id="bar-delete-btn-exams" class="bar-delete-btn">
                <i class="fa-solid fa-trash"></i> Borrar
            </button>
            <button id="bar-close-btn-exams" class="bar-close-btn">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
    </div>

    <!-- Selection Modal -->
    <div id="selection-modal-exams" class="modal-selection-overlay hidden">
        <div class="modal-selection-content">
            <div class="modal-selection-header">
                <h4>Exámenes del día</h4>
                <button id="close-selection-modal-exams">&times;</button>
            </div>
            <div id="selection-list-exams" class="selection-list">
                <!-- Filled by JS -->
            </div>
        </div>
    </div>
</div>

