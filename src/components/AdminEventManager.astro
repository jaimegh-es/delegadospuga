    .bar-edit-btn { background: #10b981; color: white; }
    .bar-delete-btn { background: #fee2e2; color: #ef4444; }
    .bar-close-btn { background: #f1f5f9; color: #475569; max-width: 50px; }

    /* TipTap Editor Styles */
    .tiptap-container {
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        background: white;
        overflow: hidden;
        margin-bottom: 1rem;
        width: 100%;
        max-width: 100%;
        box-sizing: border-box;
    }
    .tiptap-toolbar {
        background-color: #f8fafc;
        border-bottom: 1px solid #cbd5e1;
        padding: 0.5rem;
        display: flex;
        flex-wrap: nowrap;
        overflow-x: auto;
        gap: 0.5rem;
        scrollbar-width: none;
    }
    .tiptap-toolbar::-webkit-scrollbar {
        display: none;
    }
    .toolbar-group {
        display: flex;
        gap: 0.25rem;
        padding-right: 0.5rem;
        border-right: 1px solid #e2e8f0;
        flex-shrink: 0;
    }
    .toolbar-group:last-child {
        border-right: none;
    }
    .tiptap-toolbar button {
        padding: 0.5rem;
        border-radius: 4px;
        border: 1px solid transparent;
        background: transparent;
        cursor: pointer;
        font-size: 0.875rem;
        color: #475569;
        transition: all 0.2s;
        display: flex;
        align-items: center;
