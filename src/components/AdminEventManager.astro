<div class="admin-card">
    <h3>Gestión de Eventos</h3>

    <!-- Formulario Eventos -->
    <div id="event-manager-content">
        <h4 id="event-form-title" class="form-title">Añadir Evento</h4>
        <form id="event-form" class="event-form">
            <input type="hidden" name="id" id="event-id">
            <input type="hidden" name="type" value="event">
            
            <div class="form-group">
                <label>Fecha:</label>
                <input type="date" name="date" id="event-date" required>
            </div>

            <div class="form-group">
                <label>Título del Evento:</label>
                <input type="text" name="title" id="event-title" required placeholder="Ej: Excursión, Festivo...">
            </div>

             <div class="form-group">
                <label>Hora (Opcional):</label>
                <input type="text" name="time" id="event-time" placeholder="Ej: Todo el día">
            </div>

            <div class="form-group full-width">
                <label>Detalles:</label>
                <div class="tiptap-container">
                    <div id="toolbar-events" class="tiptap-toolbar">
                        <div class="toolbar-group">
                            <button type="button" data-action="bold" title="Negrita"><i class="fas fa-bold"></i></button>
                            <button type="button" data-action="italic" title="Cursiva"><i class="fas fa-italic"></i></button>
                            <button type="button" data-action="underline" title="Subrayado"><i class="fas fa-underline"></i></button>
                        </div>
                        <div class="toolbar-group">
                            <button type="button" data-action="h2" title="Título 2">H2</button>
                            <button type="button" data-action="h3" title="Título 3">H3</button>
                        </div>
                        <div class="toolbar-group">
                            <button type="button" data-action="bulletList" title="Lista Viñetas"><i class="fas fa-list-ul"></i></button>
                            <button type="button" data-action="orderedList" title="Lista Numerada"><i class="fas fa-list-ol"></i></button>
                        </div>
                        <div class="toolbar-group">
                            <button type="button" data-action="link" title="Enlace"><i class="fas fa-link"></i></button>
                            <button type="button" data-action="unlink" title="Quitar Enlace"><i class="fas fa-unlink"></i></button>
                            <button type="button" data-action="btnLink" title="Añadir Botón" class="btn-toolbar-special"><i class="fas fa-external-link-alt"></i> Botón</button>
                        </div>
                        <div class="toolbar-group">
                            <button type="button" data-action="undo" title="Deshacer"><i class="fas fa-undo"></i></button>
                            <button type="button" data-action="redo" title="Rehacer"><i class="fas fa-redo"></i></button>
                        </div>
                    </div>
                    <div id="editor-events" class="tiptap-editor"></div>
                </div>
                <input type="hidden" name="details" id="hidden-details-events">
            </div>

            <div class="form-actions">
                <button type="button" id="cancel-event-edit" class="secondary-btn hidden">Cancelar Edición</button>
                <button type="submit" class="submit-btn" id="event-submit-btn">Añadir Evento</button>
            </div>
        </form>
    </div>

    <!-- Vista Calendario -->
    <div class="calendar-preview-section">
        <div class="section-header-preview">
            <h4>Vista Previa Eventos</h4>
            <p class="hint-preview">Pasa el ratón para editar o borrar</p>
        </div>
        
        <div class="month-controls">
            <button id="prev-month-events">&lt;</button>
            <h3 id="current-month-display-events" class="mes-titulo"></h3>
            <button id="next-month-events">&gt;</button>
        </div>
        
        <div class="mes-container">
            <div class="mes">
                <table class="calendario-tabla">
                    <thead>
                        <tr>
                            <th>L</th>
                            <th>M</th>
                            <th>X</th>
                            <th>J</th>
                            <th>V</th>
                            <th>S</th>
                            <th>D</th>
                        </tr>
                    </thead>
                    <tbody id="admin-event-calendar-body">
                        <!-- Filled by JS -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Bottom Bar for Actions -->
    <div id="mobile-action-bar-events" class="bottom-action-bar">
        <div class="selected-info">
            <span id="selected-event-name"></span>
        </div>
        <div class="action-buttons">
            <button id="bar-edit-btn-events" class="bar-edit-btn">
                <i class="fa-solid fa-pen-to-square"></i> Editar
            </button>
            <button id="bar-delete-btn-events" class="bar-delete-btn">
                <i class="fa-solid fa-trash"></i> Borrar
            </button>
            <button id="bar-close-btn-events" class="bar-close-btn">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
    </div>

    <!-- Selection Modal -->
    <div id="selection-modal-events" class="modal-selection-overlay hidden">
        <div class="modal-selection-content">
            <div class="modal-selection-header">
                <h4>Eventos del día</h4>
                <button id="close-selection-modal-events">&times;</button>
            </div>
            <div id="selection-list-events" class="selection-list">
                <!-- Filled by JS -->
            </div>
        </div>
    </div>
</div>

<style>
    /* Selection Modal Styles */
    .modal-selection-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 3000;
        padding: 1rem;
    }

    .modal-selection-content {
        background: white;
        border-radius: 12px;
        width: 100%;
        max-width: 400px;
        overflow: hidden;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
    }

    .modal-selection-header {
        padding: 1rem;
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .modal-selection-header h4 {
        margin: 0;
        color: #1e293b;
    }

    .modal-selection-header button {
        background: none;
        border: none;
        font-size: 1.5rem;
        cursor: pointer;
        color: #64748b;
    }

    .selection-list {
        max-height: 300px;
        overflow-y: auto;
    }

    :global(.selection-item) {
        padding: 1rem;
        border-bottom: 1px solid #f1f5f9;
        cursor: pointer;
        transition: background 0.2s;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    :global(.selection-item:hover) {
        background: #f8fafc;
    }

    :global(.selection-item .item-title) {
        font-weight: 700;
        color: #10b981;
    }

    :global(.selection-item .item-time) {
        font-size: 0.85rem;
        color: #64748b;
    }

    /* Bottom Action Bar enhancements */
    .bottom-action-bar {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: white;
        box-shadow: 0 -4px 15px rgba(0,0,0,0.1);
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        z-index: 2000;
