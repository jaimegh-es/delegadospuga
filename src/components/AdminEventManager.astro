    .mes-container {
        max-width: 600px;
        margin: 0 auto;
    }

    .mes {
        background: #f8fafc;
        border-radius: 16px;
        padding: 24px;
        border: 1px solid #e2e8f0;
    }

    .mes-titulo {
        font-size: 1.5rem;
        font-weight: 600;
        color: #10b981;
        margin: 0;
        text-align: center;
    }

    .calendario-tabla {
        width: 100%;
        border-collapse: collapse;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        overflow: hidden;
    }

    .calendario-tabla th {
        background: linear-gradient(45deg, #10b981, #059669);
        color: white;
        padding: 12px 8px;
