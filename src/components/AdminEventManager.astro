    }
    .tiptap-editor :global(h2) { font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem; color: #1e293b; }
    .tiptap-editor :global(h3) { font-size: 1.1rem; font-weight: 600; margin-bottom: 0.4rem; color: #1e293b; }
