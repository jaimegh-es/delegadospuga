        padding: 4px;
        cursor: pointer;
        transition: background 0.2s;
    }

    :global(.calendario-tabla td:hover:not(.dia-vacio)) {
        background: #f1f5f9;
    }

    :global(.dia.tiene-evento) {
        background: #ecfdf5;
        border-top: 3px solid #10b981 !important;
    }

    :global(.dia.tiene-evento.selected) {
        background: #10b981;
        color: white;
    }

    :global(.numero-dia) {
        position: absolute;
        top: 4px;
        left: 6px;
        font-weight: 600;
        font-size: 0.875rem;
    }

    :global(.examen-info) {
        position: absolute;
        bottom: 4px;
        left: 4px;
        right: 4px;
        text-align: center;
        font-size: 0.6rem;
        line-height: 1.1;
        pointer-events: none;
    }

    :global(.examen-info .asignatura) {
        font-weight: 700;
        text-transform: uppercase;
    }
</style>

<script>
    import { Editor } from '@tiptap/core';
    import StarterKit from '@tiptap/starter-kit';
    import Link from '@tiptap/extension-link';
    import Placeholder from '@tiptap/extension-placeholder';
    import Underline from '@tiptap/extension-underline';

    let currentDate = new Date();
    let eventsData = [];
    let tiptapEvents;

    function initTipTap() {
        tiptapEvents = new Editor({
            element: document.querySelector('#editor-events'),
            extensions: [
                StarterKit,
                Underline,
                Link.configure({
                    openOnClick: false,
                    HTMLAttributes: {
                        class: null,
                    },
                }),
                Placeholder.configure({
                    placeholder: 'Detalles del evento...',
                }),
            ],
            content: '',
            onUpdate: ({ editor }) => {
                const html = editor.getHTML();
                (document.getElementById('hidden-details-events') as HTMLInputElement).value = html;
                updateToolbarState();
            },
            onSelectionUpdate: () => {
                updateToolbarState();
            }
        });

        setupToolbarListeners();
    }

    function setupToolbarListeners() {
        const toolbar = document.getElementById('toolbar-events');
        if (!toolbar) return;

        toolbar.querySelectorAll('button').forEach(btn => {
            btn.addEventListener('click', async (e) => {
                e.preventDefault();
                const action = btn.dataset.action;
                
                switch(action) {
                    case 'bold': tiptapEvents.chain().focus().toggleBold().run(); break;
                    case 'italic': tiptapEvents.chain().focus().toggleItalic().run(); break;
                    case 'underline': tiptapEvents.chain().focus().toggleUnderline().run(); break;
                    case 'h2': tiptapEvents.chain().focus().toggleHeading({ level: 2 }).run(); break;
                    case 'h3': tiptapEvents.chain().focus().toggleHeading({ level: 3 }).run(); break;
                    case 'bulletList': tiptapEvents.chain().focus().toggleBulletList().run(); break;
                    case 'orderedList': tiptapEvents.chain().focus().toggleOrderedList().run(); break;
                    case 'undo': tiptapEvents.chain().focus().undo().run(); break;
                    case 'redo': tiptapEvents.chain().focus().redo().run(); break;
                    case 'link': 
                        const url = await (window as any).showPrompt('URL del enlace:');
                        if (url) tiptapEvents.chain().focus().setLink({ href: url }).run();
                        break;
                    case 'unlink': tiptapEvents.chain().focus().unsetLink().run(); break;
                    case 'btnLink':
                        const btnUrl = await (window as any).showPrompt('URL del botón:');
                        const btnText = await (window as any).showPrompt('Texto del botón:', 'Ver más');
                        if (btnUrl && btnText) {
                            tiptapEvents.chain().focus().insertContent(`<a href="${btnUrl}" class="btn-link">${btnText}</a>`).run();
                        }
                        break;
                }
                updateToolbarState();
            });
        });
    }

    function updateToolbarState() {
        const toolbar = document.getElementById('toolbar-events');
        if (!toolbar || !tiptapEvents) return;

        toolbar.querySelectorAll('button').forEach(btn => {
            const action = btn.dataset.action;
            let isActive = false;

            if (['bold', 'italic', 'underline', 'bulletList', 'orderedList'].includes(action)) {
                isActive = tiptapEvents.isActive(action);
            } else if (['h2', 'h3'].includes(action)) {
                const level = parseInt(action.replace('h', ''));
                isActive = tiptapEvents.isActive('heading', { level });
            }

            if (isActive) btn.classList.add('active');
            else btn.classList.remove('active');
        });
    }

    async function loadEvents() {
        try {
            const res = await fetch('/api/calendar');
            const allData = await res.json();
            eventsData = allData.filter(e => e.type === 'event');
            renderCalendar();
        } catch (e) {
            console.error("Error loading events", e);
        }
    }

    function renderCalendar() {
        const tbody = document.getElementById('admin-event-calendar-body');
        const monthDisplay = document.getElementById('current-month-display-events');
        
        if (!tbody || !monthDisplay) return;

        const year = currentDate.getFullYear();
        const month = currentDate.getMonth();

        monthDisplay.textContent = new Date(year, month).toLocaleDateString('es-ES', { month: 'long', year: 'numeric' });

        const daysInMonth = new Date(year, month + 1, 0).getDate();
        const firstDay = new Date(year, month, 1).getDay();
        const adjustedFirstDay = firstDay === 0 ? 6 : firstDay - 1;

        tbody.innerHTML = '';
        
        let currentDay = 1;
        let row = document.createElement('tr');
        let dayCount = 0;

        for (let i = 0; i < adjustedFirstDay; i++) {
            const cell = document.createElement('td');
            cell.className = 'dia-vacio';
            row.appendChild(cell);
            dayCount++;
        }

        while (currentDay <= daysInMonth) {
            if (dayCount === 7) {
                tbody.appendChild(row);
                row = document.createElement('tr');
                dayCount = 0;
            }

            const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(currentDay).padStart(2, '0')}`;
            const dayEvents = eventsData.filter(e => e.date === dateStr);
            const hasEvent = dayEvents.length > 0;
            
            const cell = document.createElement('td');
            cell.className = hasEvent ? 'dia tiene-evento' : 'dia';
            cell.dataset.date = dateStr;

            cell.addEventListener('click', () => handleDayClick(dateStr));

            let content = `<div class="numero-dia">${currentDay}</div>`;
            
            if (hasEvent) {
                 content += `<div class="examen-info">`;
                 dayEvents.slice(0, 2).forEach(ev => {
                     content += `<div class="asignatura">${ev.title}</div>`;
                 });
                 if (dayEvents.length > 2) content += `<div class="asignatura">+${dayEvents.length - 2}</div>`;
                 content += `</div>`;
            }

            cell.innerHTML = content;
            row.appendChild(cell);
            currentDay++;
            dayCount++;
        }

        while (dayCount < 7 && dayCount > 0) {
            const cell = document.createElement('td');
            cell.className = 'dia-vacio';
            row.appendChild(cell);
            dayCount++;
        }
        if (row.children.length > 0) tbody.appendChild(row);
    }

    let selectedId = null;
    const mobileBar = document.getElementById('mobile-action-bar-events');
    const selectionModal = document.getElementById('selection-modal-events');
    const selectionList = document.getElementById('selection-list-events');

    function handleDayClick(dateStr) {
        const dayEvents = eventsData.filter(e => e.date === dateStr);
        if (dayEvents.length === 0) {
            closeMobileActionBar();
            return;
        }

        if (dayEvents.length === 1) {
            selectItem(dayEvents[0].id);
        } else {
            showSelectionList(dayEvents);
        }
    }

    function showSelectionList(events) {
        selectionList.innerHTML = '';
        events.forEach(ev => {
            const item = document.createElement('div');
            item.className = 'selection-item';
            item.innerHTML = `
                <span class="item-title">${ev.title}</span>
                <span class="item-time">${ev.time || 'Todo el día'}</span>
            `;
            item.onclick = () => {
                selectItem(ev.id);
                closeSelectionModal();
            };
            selectionList.appendChild(item);
        });
        selectionModal.classList.remove('hidden');
    }

    function closeSelectionModal() {
        selectionModal.classList.add('hidden');
    }

    function selectItem(id) {
        selectedId = id;
        const item = eventsData.find(e => e.id === id);
        if (!item) return;

        document.getElementById('selected-event-name').textContent = item.title;
        mobileBar.classList.add('active');

        // Highlight in calendar
        document.querySelectorAll('.dia').forEach(d => d.classList.remove('selected'));
        const cell = document.querySelector(`td[data-date="${item.date}"]`);
        if (cell) cell.classList.add('selected');
    }

    function closeMobileActionBar() {
        mobileBar.classList.remove('active');
        selectedId = null;
        document.querySelectorAll('.dia').forEach(d => d.classList.remove('selected'));
    }

    (window as any).editEventItem = (id) => {
        (window as any).showLoading();
        
        setTimeout(() => {
            const item = eventsData.find(e => e.id === id);
            if (!item) {
                (window as any).hideLoading();
                return;
            }

            (document.getElementById('event-id') as HTMLInputElement).value = item.id;
            (document.getElementById('event-date') as HTMLInputElement).value = item.date;
            (document.getElementById('event-title') as HTMLInputElement).value = item.title;
            (document.getElementById('event-time') as HTMLInputElement).value = item.time || '';
            tiptapEvents.commands.setContent(item.details || '');

            document.getElementById('event-form-title').textContent = "Editar Evento";
            document.getElementById('event-submit-btn').textContent = "Actualizar Evento";
            document.getElementById('cancel-event-edit').classList.remove('hidden');
            
            window.scrollTo({ top: document.getElementById('event-manager-content').offsetTop - 100, behavior: 'smooth' });
            closeMobileActionBar();
            
            (window as any).hideLoading();
        }, 300);
    };

    function resetEventsForm() {
        (window as any).showLoading();
        
        setTimeout(() => {
            const form = document.getElementById('event-form') as HTMLFormElement;
            form.reset();
            (document.getElementById('event-id') as HTMLInputElement).value = '';
            tiptapEvents.commands.setContent('');
            document.getElementById('event-form-title').textContent = "Añadir Evento";
            document.getElementById('event-submit-btn').textContent = "Añadir Evento";
            document.getElementById('cancel-event-edit').classList.add('hidden');
            
            (window as any).hideLoading();
        }, 300);
    }

    async function deleteEventItem(id) {
        const confirmed = await (window as any).showConfirm("¿Borrar este evento?");
        if (!confirmed) return;

        (window as any).showLoading();
        try {
            const res = await fetch('/api/calendar', {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id })
            });

            if (res.ok) {
                closeMobileActionBar();
                await loadEvents();
                (window as any).showAlert("Evento borrado correctamente", "success");
            } else {
                (window as any).showAlert("Error al borrar", "error");
            }
        } catch (e) {
            (window as any).showAlert("Error de conexión", "error");
        } finally {
            (window as any).hideLoading();
        }
    }
    (window as any).deleteEventItem = deleteEventItem;

    async function handleFormSubmit(e) {
        e.preventDefault();
        const form = e.target;
        
        (window as any).showLoading();
        
        (document.getElementById('hidden-details-events') as HTMLInputElement).value = tiptapEvents.getHTML();

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        
        try {
            const res = await fetch('/api/calendar', {
                method: data.id ? 'PATCH' : 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            if (res.ok) {
                resetEventsForm();
                await loadEvents();
                (window as any).showAlert("Evento guardado correctamente", "success");

                // Preguntar para Telegram
                const publishInTelegram = await (window as any).showConfirm("¿Quieres avisar de este evento en Telegram también?");
                if (publishInTelegram) {
                    (window as any).showLoading();
                    try {
                        const siteUrl = window.location.origin;
                        await fetch('/api/telegram', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                title: `📢 EVENTO: ${data.title}`,
                                subtitle: `Fecha: ${new Date(data.date as string).toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long' })}${data.time ? ` a las ${data.time}` : ''}`,
                                link: `${siteUrl}/dashboard`
                            })
                        });
                        (window as any).showAlert("Aviso enviado a Telegram", "success");
                    } catch (e) {
                        (window as any).showAlert("Error enviando a Telegram", "error");
                    } finally {
                        (window as any).hideLoading();
                    }
                }
            } else {
                (window as any).showAlert("Error al guardar", "error");
            }
        } catch (e) {
            (window as any).showAlert("Error de conexión", "error");
        } finally {
            (window as any).hideLoading();
        }
    }

    document.addEventListener('DOMContentLoaded', async () => {
        (window as any).showLoading();
        initTipTap();
        await loadEvents();
        document.getElementById('event-form')?.addEventListener('submit', handleFormSubmit);
        document.getElementById('cancel-event-edit')?.addEventListener('click', resetEventsForm);
        document.getElementById('prev-month-events')?.addEventListener('click', async () => { 
            (window as any).showLoading();
            currentDate.setMonth(currentDate.getMonth() - 1); 
            renderCalendar(); 
            (window as any).hideLoading();
        });
        document.getElementById('next-month-events')?.addEventListener('click', async () => { 
            (window as any).showLoading();
            currentDate.setMonth(currentDate.getMonth() + 1); 
            renderCalendar(); 
            (window as any).hideLoading();
        });

        document.getElementById('bar-edit-btn-events')?.addEventListener('click', () => {
            if (selectedId) (window as any).editEventItem(selectedId);
        });
        document.getElementById('bar-delete-btn-events')?.addEventListener('click', () => {
            if (selectedId) deleteEventItem(selectedId);
        });
        document.getElementById('bar-close-btn-events')?.addEventListener('click', closeMobileActionBar);
        document.getElementById('close-selection-modal-events')?.addEventListener('click', closeSelectionModal);
        
        (window as any).hideLoading();
    });
</script>
