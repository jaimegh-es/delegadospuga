---
// ChatBot.astro - Estilo integrado con la web y nombres de clases únicos
---

<div class="chatbot-wrapper">
    <!-- Burbuja flotante inicial -->
    <div id="chatbot-bubble" class="chatbot-bubble">
        <p>¡Hola! Pregúntame tus dudas sobre el reglamento del centro aquí. 🤖</p>
        <button id="close-chatbot-bubble" class="close-bubble" aria-label="Cerrar mensaje">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>

    <!-- Botón principal -->
    <button 
        id="chatbot-trigger"
        class="chatbot-main-btn"
        aria-label="Abrir Chatbot de Reglamento"
    >
        <i class="fa-solid fa-comment-dots"></i>
    </button>

    <!-- Modal de Advertencia -->
    <div id="chatbot-modal" class="chatbot-modal-overlay" style="display: none;">
        <div class="chatbot-modal-content">
            <div class="chatbot-modal-header">
                <div class="header-icon">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
                <h2>Aviso Importante</h2>
            </div>
            <div class="chatbot-modal-body">
                <p>Este chatbot está entrenado <strong>exclusivamente con el reglamento interno del centro</strong>.</p>
                <p>Para consultas sobre la legalidad general de ciertos asuntos o normativas externas, te recomendamos utilizar IAs generales como <a href="https://www.perplexity.ai" target="_blank">Perplexity</a> o <a href="https://gemini.google.com" target="_blank">Gemini</a>.</p>
            </div>
            <div class="chatbot-modal-footer">
                <button id="cancel-chatbot" class="chatbot-btn-secondary">Volver</button>
                <a 
                    href="https://notebooklm.google.com/notebook/137d0039-723d-43f9-9b82-6b98c5ed0ebd" 
                    target="_blank" 
                    id="confirm-chatbot" 
                    class="chatbot-btn-primary"
                >Entendido, ir al Chat</a>
            </div>
        </div>
    </div>
</div>

<style is:global>
    /* Usamos nombres de clase muy específicos para no interferir con el Hero u otros componentes */
    .chatbot-wrapper {
        z-index: 10010;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        pointer-events: none;
    }

    .chatbot-main-btn {
        pointer-events: auto;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: #2000ad; /* Azul de la web */
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.2);
        cursor: pointer;
        display: flex;
        justify-content: center;
        align-items: center;
        box-shadow: 0 10px 30px rgba(32, 0, 173, 0.3);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        font-size: 1.6rem;
    }

    .chatbot-main-btn:hover {
        transform: scale(1.1) translateY(-2px);
        background: #1a008c;
        box-shadow: 0 15px 40px rgba(32, 0, 173, 0.4);
    }

    /* Burbuja */
    .chatbot-bubble {
        pointer-events: auto;
        position: relative;
        margin-bottom: 15px;
        width: 260px;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        padding: 15px 35px 15px 15px;
        border-radius: 20px 20px 5px 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        font-size: 0.9rem;
        line-height: 1.5;
        color: #1a1a1a;
        border: 1px solid rgba(32, 0, 173, 0.1);
        animation: chatbotBubblePop 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        transform-origin: bottom right;
    }

    .chatbot-bubble::after {
        content: '';
        position: absolute;
        bottom: -8px;
        right: 20px;
        border-left: 10px solid transparent;
        border-right: 10px solid transparent;
        border-top: 10px solid rgba(255, 255, 255, 0.95);
    }

    .close-bubble {
        position: absolute;
        top: 8px;
        right: 8px;
        background: none;
        border: none;
        color: #999;
        cursor: pointer;
        padding: 5px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        transition: all 0.2s;
    }

    .close-bubble:hover {
        background: rgba(32, 0, 173, 0.05);
        color: #2000ad;
    }

    /* Modal Overlay */
    .chatbot-modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(8px);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 99999; /* Máxima prioridad */
        pointer-events: auto;
        padding: 20px;
    }

    .chatbot-modal-content {
        background: white;
        width: 100%;
        max-width: 480px;
        border-radius: 28px;
        padding: 35px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        border: 1px solid rgba(32, 0, 173, 0.1);
        animation: chatbotModalFadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .chatbot-modal-header {
        text-align: center;
        margin-bottom: 25px;
    }

    .header-icon {
        width: 64px;
        height: 64px;
        background: rgba(32, 0, 173, 0.05);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        color: #2000ad;
        font-size: 1.75rem;
    }

    .chatbot-modal-header h2 {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 800;
        color: #0f172a;
        letter-spacing: -0.02em;
    }

    .chatbot-modal-body {
        color: #475569;
        line-height: 1.6;
        font-size: 1.05rem;
    }

    .chatbot-modal-body p {
        margin-bottom: 15px;
    }

    .chatbot-modal-body strong {
        color: #0f172a;
    }

    .chatbot-modal-body a {
        color: #2000ad;
        text-decoration: none;
        font-weight: 700;
        border-bottom: 2px solid rgba(32, 0, 173, 0.2);
        transition: all 0.2s;
    }

    .chatbot-modal-body a:hover {
        border-bottom-color: #2000ad;
        background: rgba(32, 0, 173, 0.05);
    }

    .chatbot-modal-footer {
        display: flex;
        justify-content: stretch;
        gap: 12px;
        margin-top: 30px;
    }

    .chatbot-btn-primary, .chatbot-btn-secondary {
        flex: 1;
        padding: 14px 24px;
        border-radius: 16px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        font-size: 1rem;
        border: none;
        text-decoration: none;
        text-align: center;
        display: inline-block;
    }

    .chatbot-btn-primary {
        background: #2000ad;
        color: white;
        box-shadow: 0 4px 12px rgba(32, 0, 173, 0.2);
    }

    .chatbot-btn-primary:hover {
        background: #1a008c;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(32, 0, 173, 0.3);
    }

    .chatbot-btn-secondary {
        background: #f1f5f9;
        color: #64748b;
    }

    .chatbot-btn-secondary:hover {
        background: #e2e8f0;
        color: #0f172a;
    }

    @keyframes chatbotBubblePop {
        from { opacity: 0; transform: scale(0.8) translateY(10px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }

    @keyframes chatbotModalFadeIn {
        from { opacity: 0; transform: scale(0.95) translateY(10px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }

    @media (max-width: 480px) {
        .chatbot-wrapper { right: 30px; }
        .chatbot-modal-footer { flex-direction: column; }
        .chatbot-modal-content { padding: 25px; }
    }
</style>

<script>
    const bubble = document.getElementById('chatbot-bubble');
    const closeBtn = document.getElementById('close-chatbot-bubble');
    const trigger = document.getElementById('chatbot-trigger');
    const modal = document.getElementById('chatbot-modal');
    const cancelBtn = document.getElementById('cancel-chatbot');
    const confirmBtn = document.getElementById('confirm-chatbot');

    // MOVER MODAL AL BODY (Portal)
    // Esto es crucial para que el modal no se vea afectado por el transform del contenedor
    if (modal) {
        document.body.appendChild(modal);
    }

    // Manejo de la burbuja
    if (localStorage.getItem('chatbot-bubble-closed') === 'true') {
        if (bubble) bubble.style.display = 'none';
    }

    closeBtn?.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        if (bubble) {
            bubble.style.transition = 'all 0.3s ease-in';
            bubble.style.opacity = '0';
            bubble.style.transform = 'scale(0.8) translateY(10px)';
            setTimeout(() => {
                bubble.style.display = 'none';
                localStorage.setItem('chatbot-bubble-closed', 'true');
            }, 300);
        }
    });

    // Abrir Modal
    trigger?.addEventListener('click', () => {
        if (modal) {
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }
    });

    // Cerrar Modal (Cancelar)
    const closeModal = () => {
        if (modal) {
            modal.style.display = 'none';
            document.body.style.overflow = '';
        }
    };

    cancelBtn?.addEventListener('click', closeModal);
    
    confirmBtn?.addEventListener('click', () => {
        setTimeout(closeModal, 500);
    });

    modal?.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
    });
</script>