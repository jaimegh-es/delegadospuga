---
// TelegramFloatingBtn.astro - Unificado con el estilo de la web
---

<div class="telegram-floating-wrapper">
    <a 
        href="https://t.me/+Itq-KhGnWLZiNTZk" 
        target="_blank" 
        rel="noopener noreferrer"
        class="telegram-floating-btn"
        aria-label="Unirse al canal de Telegram"
    >
        <i class="fab fa-telegram-plane"></i>
    </a>
</div>

<style is:global>
    .telegram-floating-wrapper {
        z-index: 10000;
        pointer-events: none;
    }

    .telegram-floating-btn {
        pointer-events: auto;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: #2000ad; /* Unificado con el resto */
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.2);
        cursor: pointer;
        display: flex;
        justify-content: center;
        align-items: center;
        box-shadow: 0 10px 30px rgba(32, 0, 173, 0.3);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        text-decoration: none;
        font-size: 1.6rem; /* Unificado con el chatbot */
    }

    .telegram-floating-btn:hover {
        transform: scale(1.1) translateY(-2px);
        background: #1a008c;
        box-shadow: 0 15px 40px rgba(32, 0, 173, 0.4);
        color: white;
    }

    /* Mantenemos el tamaño en móvil para consistencia */
    @media (max-width: 768px) {
        .telegram-floating-wrapper {
            right: 30px; /* Aseguramos alineación */
        }
    }
</style>
