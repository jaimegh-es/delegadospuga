---
import { pwaInfo } from "virtual:pwa-info";
import TelegramPopup from "../components/TelegramPopup.astro";
import "../styles/global.css";

interface Props {
	title?: string;
}

const { title = "1B Bach | La página que usan los compañeros y sus padres 🤣" } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<!-- Start cookieyes banner --> <script id="cookieyes" type="text/javascript" src="https://cdn-cookieyes.com/client_data/0c367db80bd292c4acc3450f14a26074/script.js"></script> <!-- End cookieyes banner -->
		<script type="text/plain" data-cookieyes="cookiecategory-analytics">
			(function(c,l,a,r,i,t,y){
				c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
				t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
				y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
			})(window, document, "clarity", "script", "wesswb57ab");
		</script>
		<meta charset="UTF-8" />
		<meta http-equiv="Content-Security-Policy" content="script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com https://apis.google.com https://www.gstatic.com https://vercel.live https://cdn.jsdelivr.net https://cdn-cookieyes.com https://www.clarity.ms; connect-src 'self' https://*.googleapis.com https://*.firebaseapp.com https://*.cookieyes.com https://*.clarity.ms https://*.google.com https://vercel.live https://cdn.jsdelivr.net;">
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Sí, es aquí. La reducción a código de todo lo que necesitas." />
		<title>{title}</title> 
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Oswald:wght@200..700&display=swap"
			rel="stylesheet"
		/>
		<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap" rel="stylesheet">
		<link
			rel="stylesheet"
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
		/>
		<meta
			name="google-site-verification"
			content="9ZLJootCsdX0ar_N77lazLJnwImUq-2T5BvRGINna7k"
		/>
		{pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
		<script
			src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"
			is:inline
		></script>
		<script
			src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"
			is:inline
		></script>
	</head>
	<body>
		<!-- Top Progress Bar -->
		<div id="loading-bar-container" class="progress-bar-container">
			<div id="loading-bar" class="progress-bar"></div>
		</div>

		<slot />
		<TelegramPopup />
	</body>
	<script>
		import { registerSW } from "virtual:pwa-register";

		// Manejo de la Barra de Progreso
		let progressInterval: any;
		let startTime = Date.now();
		const MIN_LOADING_TIME = 800; // ms para que el usuario lo note
		
		const finishProgress = () => {
			const bar = document.getElementById('loading-bar');
			if (bar) {
				const elapsedTime = Date.now() - startTime;
				const remainingTime = Math.max(0, MIN_LOADING_TIME - elapsedTime);

				setTimeout(() => {
					clearInterval(progressInterval);
					bar.style.width = '100%';
					setTimeout(() => {
						bar.style.opacity = '0';
						setTimeout(() => {
							bar.style.width = '0%';
							bar.style.display = 'none';
						}, 300);
					}, 200);
				}, remainingTime);
			}
		};

		const startProgress = () => {
			const bar = document.getElementById('loading-bar');
			if (bar) {
				startTime = Date.now();
				bar.style.display = 'block';
				bar.style.opacity = '1';
				bar.style.width = '0%';
				
				// Avance inicial rápido
				setTimeout(() => { bar.style.width = '40%'; }, 10);
				
				// Avance lento hasta el 95%
				let currentWidth = 40;
				clearInterval(progressInterval);
				progressInterval = setInterval(() => {
					if (currentWidth < 95) {
						currentWidth += Math.random() * 1.5;
						bar.style.width = `${currentWidth}%`;
					}
				}, 150);
			}
		};

		// Iniciar progreso inmediatamente al cargar el script (para el primer render)
		startProgress();

		// Exponer globalmente
		(window as any).showLoading = startProgress;
		(window as any).hideLoading = finishProgress;

		// Ejecutar al terminar la carga total de la página
		if (document.readyState === 'complete') {
			finishProgress();
		} else {
			window.addEventListener('load', finishProgress);
		}
		
		// Manejar navegación hacia atrás (bfcache)
		window.addEventListener('pageshow', (event) => {
			if (event.persisted) {
				finishProgress();
			}
		});

		// Interceptar clicks en enlaces internos para mostrar progreso inmediatamente
		document.addEventListener('click', (e) => {
			const target = (e.target as HTMLElement).closest('a');
			
			if (target && target instanceof HTMLAnchorElement) {
				const url = new URL(target.href);
				const isInternal = url.origin === window.location.origin;
				const isSamePage = url.pathname === window.location.pathname;
				const hasHash = !!url.hash;
				const isTargetBlank = target.target === '_blank';
				const isDownload = target.hasAttribute('download');

				if (isInternal && !(isSamePage && hasHash) && !isTargetBlank && !isDownload) {
					if (target.getAttribute('href') === '#' || target.getAttribute('href')?.startsWith('#')) {
						return;
					}
					startProgress();
				}
			}
		});

		// Limpiar cachés antiguos primero
		if ("caches" in window) {
			caches.keys().then(function (cacheNames) {
				return Promise.all(
					cacheNames.map(function (cacheName) {
						// Eliminar cachés que no sean de imágenes
						if (!cacheName.includes("images-cache")) {
							console.log("Eliminando caché antiguo:", cacheName);
							return caches.delete(cacheName);
						}
					}),
				);
			});
		}

		registerSW({
			immediate: true,
			onRegistered(r) {
				console.log("SW Registered:", r);
				// Verificar actualizaciones cada 30 segundos
				if (r) {
					setInterval(() => {
						r.update();
					}, 30000);
				}
			},
			onRegisterError(error) {
				console.log("SW registration error", error);
			},
			onNeedRefresh() {
				console.log("Nueva versión disponible, recargando...");
				window.location.reload();
			},
		});
	</script>
</html>

<style is:global>
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
		font-family:
			"Inter",
			-apple-system,
			BlinkMacSystemFont,
			"Segoe UI",
			sans-serif;
	}

	body {
		line-height: 1.6;
		color: #1f2937;
		background: rgb(208, 207, 207);
		overflow-x: hidden;
	}

	::-webkit-scrollbar {
		width: 8px;
	}

	::-webkit-scrollbar-track {
		background: #f1f5f9;
	}

	::-webkit-scrollbar-thumb {
		background: #2000ad;
		border-radius: 4px;
	}

	::-webkit-scrollbar-thumb:hover {
		background: #002a80;
	}

	.content {
		max-width: 800px;
		margin: 40px auto;
		padding: 20px;
		background: #d7d7d7;
		border-radius: 10px;
		box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
		margin-top: 10%;
	}
	.btn-primary,
	.btn-secondary {
		padding: 16px 32px;
		text-decoration: none;
		border-radius: 50px;
		font-weight: 600;
		transition: all 0.3s ease;
		transform-style: preserve-3d;
	}

	.btn-primary {
		background: white;
		color: #2000ad;
		box-shadow: 0 8px 32px rgba(255, 255, 255, 0.4);
	}

	.btn-primary:hover {
		transform: translateY(-4px) rotateX(10deg);
		box-shadow: 0 12px 48px rgba(255, 255, 255, 0.6);
	}

	.btn-secondary {
		background: rgba(255, 255, 255, 0.1);
		color: white;
		border: 2px solid rgba(255, 255, 255, 0.3);
		backdrop-filter: blur(10px);
	}

	.btn-secondary:hover {
		background: rgba(255, 255, 255, 0.2);
		transform: translateY(-4px) rotateX(10deg);
		border-color: rgba(255, 255, 255, 0.5);
	}
	.logo {
		width: auto;
		height: 40px;
	}

	/* Top Progress Bar Styles */
	.progress-bar-container {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 4px;
		background: transparent;
		z-index: 10001;
		pointer-events: none;
	}

	.progress-bar {
		height: 100%;
		width: 0%;
		background: linear-gradient(to right, #2000ad, #4f46e5);
		transition: width 0.3s cubic-bezier(0.1, 0.05, 0.1, 1), opacity 0.3s ease;
		box-shadow: 0 0 15px rgba(32, 0, 173, 0.8), 0 0 5px rgba(32, 0, 173, 1);
		display: none;
	}
</style>
