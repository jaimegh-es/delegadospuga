---
import Layout from './Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const { frontmatter } = Astro.props;
const title = frontmatter?.title || Astro.props.title || "Recurso";
const description = frontmatter?.description || Astro.props.description || "";
---

<Layout title={title}>
	<Navigation />
	<main class="resource-container">
        <article class="resource-content prose-content">
            {(frontmatter || title !== "Recurso") && (
                <header class="resource-header">
                    <h1>{title}</h1>
                    {description && <p class="description">{description}</p>}
                    <hr />
                </header>
            )}
            <slot />
        </article>
	</main>
	<Footer />
</Layout>

<style>
    .resource-container {
        padding-top: 120px; 
        padding-bottom: 60px;
        min-height: 85vh;
        background: #f8fafc;
    }

    .resource-content {
        max-width: 900px;
        margin: 0 auto;
        padding: 3.5rem 3rem;
        background: white !important; /* Ensure it overrides global .content if misapplied */
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.04);
        border: 1px solid rgba(0, 0, 0, 0.05);
    }

    .resource-header h1 {
        margin-bottom: 0.5rem;
        color: #1e293b;
    }

    .description {
        font-size: 1.25rem;
        color: #64748b;
        margin-bottom: 1.5rem;
        font-weight: 400;
        line-height: 1.6;
    }

    @media (max-width: 768px) {
        .resource-container {
            padding-top: 100px;
        }
        .resource-content {
            padding: 2rem 1.5rem;
            margin: 0 1rem;
            border-radius: 12px;
        }
    }
</style>
