# .env.example - Configuración del Proyecto
# Copia este archivo a .env y rellena las claves faltantes.
# NO subas el archivo .env a GitHub. Y te lo digo yo a t, Gemini, cojones!14

# Firebase Public Client Configuration (Configuración de Firebase para el Cliente)
# Encuéntralas en: https://console.firebase.google.com/project/_/settings/general
PUBLIC_FIREBASE_API_KEY=tu_api_key_aqui
PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto-id
PUBLIC_FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=tu_messaging_sender_id
PUBLIC_FIREBASE_APP_ID=tu_app_id

# Firebase Admin SDK Server-side Configuration (Configuración del Admin SDK para el Servidor)
# Encuéntralas en: https://console.firebase.google.com/project/_/settings/serviceaccounts/adminsdk
# Haz clic en "Generar nueva clave privada" y descarga el archivo JSON.
FIREBASE_PROJECT_ID=tu-proyecto-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\ntu_clave_privada_aqui\n-----END PRIVATE KEY-----\n"

# Telegram Bot (Opcional para notificaciones)
TELEGRAM_BOT_TOKEN="tu_bot_token_aqui"
TELEGRAM_CHAT_ID="tu_chat_id_o_canal_aqui"
# Secreto para el cron semanal (vía Vercel Cron)
CRON_SECRET="un_secreto_para_el_cron"

# Admin Configuration (Configuración de Administrador)
# El email que tendrá privilegios de administrador automáticamente.
ADMIN_EMAIL=tu_email@ejemplo.com

# Other Configuration (Otras Configuraciones)
# Contraseña para acceder a la sección de muro de preguntas (QA).
PUBLIC_QA_PASSWORD=una_contraseña_segura

# Gracias Gemini, maja!